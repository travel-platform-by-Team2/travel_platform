<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{#page}}{{detail.formattedTitle}}{{/page}}{{^page}}여행 상세{{/page}}</title>
  {{>partials/head-assets}}
</head>
<body class="page-body-x-hidden-shell">
  {{>partials/header}}

<main class="page-main-wrap-960">
  {{#page}}
  <section class="trip-plan-detail-div-01">
    <div class="layout-content-stack-960">
      <div class="trip-plan-detail-div-02">
        <div class="trip-plan-detail-div-05">
          <h1 class="trip-plan-detail-h1-01">{{detail.formattedTitle}}</h1>
          <div class="inline-items-gap-2">
            <span class="trip-plan-detail-span-02">
              <span class="icon-ms-14-mr1">location_on</span>
              {{detail.regionLabel}}
            </span>
            <span class="trip-plan-detail-span-02">
              <span class="icon-ms-14-mr1">calendar_month</span>
              {{detail.travelPeriodLabel}}
            </span>
            <span class="trip-plan-detail-span-02">
              <span class="icon-ms-14-mr1">group</span>
              {{detail.whoWithLabel}}
            </span>
          </div>
        </div>
        <button class="trip-plan-detail-button-01" type="button" onclick="location.href='/trip/place?id={{detail.id}}'">
          <span class="icon-ms-18">add_location_alt</span>
          <span>장소 추가</span>
        </button>
      </div>
    </div>
  </section>

  <section class="layout-content-stack-960">
    <div class="trip-plan-detail-div-17">
      <h2 class="trip-plan-detail-h2-02">여행 정보</h2>
      <div class="calendar-add-event-div-06">
        <button class="text-muted-hover-primary" type="button" onclick="location.href='/trip'">
          <span class="icon-ms-base">arrow_back</span>
        </button>
      </div>
    </div>

    <div class="trip-plan-detail-div-10">
      <div class="trip-plan-detail-div-11">
        <div class="row-between-center-mb2">
          <h2 class="trip-plan-detail-h2-01">
            <span class="icon-ms-primary">calendar_today</span>
            여행 기간
          </h2>
          <span class="trip-plan-detail-span-04">{{detail.nightCountLabel}} {{detail.dayCountLabel}}</span>
        </div>
        <p class="trip-plan-detail-p-01">{{detail.dateRangeLabel}}</p>
      </div>

      <div class="trip-plan-detail-div-11">
        <div class="row-between-center-mb2">
          <h2 class="trip-plan-detail-h2-01">
            <span class="icon-ms-primary">bookmark</span>
            저장된 장소
          </h2>
          <span class="trip-plan-detail-span-04">{{detail.placeCount}}개</span>
        </div>
        {{#detail.hasPlaces}}
        <p class="trip-plan-detail-p-01">장소가 저장돼 있습니다. 아래 일정에서 확인해보세요.</p>
        {{/detail.hasPlaces}}
        {{^detail.hasPlaces}}
        <p class="trip-plan-detail-p-01">아직 저장된 장소가 없습니다. 장소 추가 버튼으로 일정을 채워보세요.</p>
        {{/detail.hasPlaces}}
      </div>
    </div>

    <div class="trip-plan-detail-div-17">
      <h2 class="trip-plan-detail-h2-02">상세 일정</h2>
    </div>

    {{#detail.hasPlaces}}
    <div class="trip-plan-detail-div-18">
      {{#detail.places}}
      <div class="timeline-card">
        <div class="row-between-center">
          <h3 class="text-main-lg-bold">DAY {{dayOrder}}</h3>
          <span class="trip-plan-detail-span-04">{{placeName}}</span>
        </div>
        <p class="trip-plan-detail-p-01">{{address}}</p>
      </div>
      {{/detail.places}}
    </div>
    {{/detail.hasPlaces}}

    {{^detail.hasPlaces}}
    <div class="empty-state">
      등록된 여행 장소가 없습니다.
    </div>
    {{/detail.hasPlaces}}

    <div class="trip-plan-detail-div-23">
      <button class="trip-plan-detail-button-03" type="button" onclick="location.href='/trip/place?id={{detail.id}}'">
        <span class="icon-ms-2xl">add_location_alt</span>
      </button>
    </div>
  </section>
  {{/page}}
</main>

  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
