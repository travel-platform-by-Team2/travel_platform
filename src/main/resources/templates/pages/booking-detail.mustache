<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>예약 상세 내역 | TravelMate</title>
  {{>partials/head-assets}}
  <link href="/css/account.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans">
  {{>partials/header}}

  <main class="account-page account-page--detail">
    <div class="booking-detail-shell booking-detail-shell--renewed">
      <div class="booking-detail-breadcrumb">
        <a href="{{model.bookingListLink}}">예약 목록으로 돌아가기</a>
        <span class="material-symbols-outlined">chevron_right</span>
        <span>예약 상세 내역</span>
      </div>

      <div class="booking-detail-hero">
        <div class="booking-detail-hero__head">
          <div class="booking-detail-hero__status">
            <div class="booking-detail-hero__icon">
              <span class="material-symbols-outlined">calendar_month</span>
            </div>
            <div>
              <p class="booking-detail-hero__label">{{model.statusLabel}}</p>
              <p class="booking-detail-hero__number">예약번호: {{model.bookingNumberText}}</p>
            </div>
          </div>

          {{#model.cancelled}}
          <span class="booking-payment-badge booking-payment-badge--cancelled">취소됨</span>
          {{/model.cancelled}}
          {{^model.cancelled}}
          <span class="booking-payment-badge booking-payment-badge--paid">결제 완료</span>
          {{/model.cancelled}}
        </div>

        <div class="booking-detail-hero__body">
          <div class="booking-detail-hero__media{{^model.hasImage}} booking-detail-hero__media--empty{{/model.hasImage}}"{{#model.hasImage}} style="background-image: url('{{model.imageUrl}}');"{{/model.hasImage}}>
            {{^model.hasImage}}
            <span class="material-symbols-outlined">hotel</span>
            {{/model.hasImage}}
          </div>

          <div class="booking-detail-hero__content">
            <h1 class="booking-detail-hero__title">{{model.lodgingName}}</h1>
            <p class="booking-detail-hero__location">
              <span class="material-symbols-outlined">location_on</span>
              {{model.location}}
            </p>
            <div class="booking-detail-hero__meta">
              <div>
                <span>일정</span>
                <strong>{{model.stayScheduleLabel}}</strong>
              </div>
              <div>
                <span>인원</span>
                <strong>{{model.guestCountLabel}}</strong>
              </div>
            </div>
            {{#model.hasTripPlanLink}}
            <a class="booking-detail-hero__link" href="{{model.tripPlanLink}}">
              여행 계획 보기
              <span class="material-symbols-outlined">chevron_right</span>
            </a>
            {{/model.hasTripPlanLink}}
          </div>
        </div>
      </div>

      <section class="booking-detail-info-card">
        <div class="booking-detail-info-card__head">
          <span class="material-symbols-outlined">receipt_long</span>
          <h2>결제 정보 상세</h2>
        </div>
        <div class="booking-detail-info-card__body">
          <div class="booking-detail-info-card__row">
            <span>객실 요금</span>
            <span>{{model.roomPriceText}}</span>
          </div>
          <div class="booking-detail-info-card__row">
            <span>세금 및 수수료</span>
            <span>{{model.feeText}}</span>
          </div>
          <div class="booking-detail-info-card__row booking-detail-info-card__row--total">
            <span>최종 결제 금액</span>
            <strong>{{model.totalPriceText}}</strong>
          </div>
        </div>
      </section>

      <section class="booking-detail-info-card">
        <div class="booking-detail-info-card__head">
          <span class="material-symbols-outlined">info</span>
          <h2>예약 처리 안내</h2>
        </div>
        <div class="booking-detail-info-card__body booking-detail-info-card__body--stack">
          <div class="booking-detail-note">
            <span>예약일시</span>
            <strong>{{model.bookingDateLabel}}</strong>
          </div>
          {{#model.cancelledAtLabel}}
          <div class="booking-detail-note">
            <span>취소일시</span>
            <strong>{{model.cancelledAtLabel}}</strong>
          </div>
          {{/model.cancelledAtLabel}}
          <div class="booking-detail-guide">
            <p>예약 취소는 삭제가 아니라 상태 변경으로 처리되고, 예약 이력은 계속 보관됩니다.</p>
            <p>취소한 예약은 예약 목록에서 상태 배지로 다시 확인할 수 있습니다.</p>
          </div>
        </div>
      </section>

      <div class="booking-detail-actions booking-detail-actions--renewed">
        <a class="account-button account-button--primary" href="{{model.mypageLink}}">
          <span class="material-symbols-outlined">home</span>
          마이페이지로 돌아가기
        </a>
        {{#model.canCancel}}
        <button
          class="account-button account-button--secondary"
          type="button"
          data-booking-cancel-button
          data-cancel-url="{{model.cancelApiUrl}}">
          <span class="material-symbols-outlined">cancel</span>
          예약 취소 요청
        </button>
        {{/model.canCancel}}
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{#model.canCancel}}
  <script>
    (function () {
      const button = document.querySelector("[data-booking-cancel-button]");
      if (!button) return;

      button.addEventListener("click", async function () {
        if (!window.confirm("예약을 취소하시겠습니까?")) {
          return;
        }

        button.disabled = true;

        try {
          const response = await fetch(button.dataset.cancelUrl, {
            method: "DELETE",
            headers: {
              Accept: "application/json"
            }
          });
          const payload = await response.json();

          if (!response.ok || !payload || payload.status !== 200) {
            throw new Error((payload && payload.msg) || "예약 취소에 실패했습니다.");
          }

          window.location.reload();
        } catch (error) {
          window.alert(error.message || "예약 취소에 실패했습니다.");
          button.disabled = false;
        }
      });
    })();
  </script>
  {{/model.canCancel}}
</body>
</html>
