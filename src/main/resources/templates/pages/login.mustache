<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate | 로그인</title>
  {{>partials/head-assets}}
  {{>partials/chatbot-assets}}
  <!-- 구글 로그인 Client ID 메타 태그 추가 (SDK 자동 인식용) -->
  <meta name="google-client_id" content="{{model.googleClientId}}">
</head>
<body class="page-body">
  {{>partials/header}}

<main class="login-main-01">
<div class="login-shell-grid">
<div class="login-div-01" data-alt="Scenic view of a traditional Korean palace at sunset" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuA3-ocK1XoagK0dQ808TPKsDD4Lw2-J16rCi-P6ExrwlYE0l4GdvvLfguP4yemfyVjh3BIC92s2o_OYgt-hmHeeSf1DklGty075K9l1cnNHY0SsCIttpsuPfJpxeLMD7LJPAott0uI9raifEDC2zyj6V3InmLxRFqDx4U0NjOjG0q3rKiUnjeSd0IJLTDQKng4HuJeLEbtLI7_d5ub_uowEd_llUuQ_mr69JzxTFhpUD-OQaCKo1Di7asmpkjHUdf2y0_ynNxAaau0");'>
<div class="login-div-02"></div>
<div class="login-div-03">
<div class="chip-glass-inline">
<span class="icon-ms-sm-white">verified</span>
<span class="login-span-01">신뢰받는 여행 플랫폼</span>
</div>
</div>
<div class="login-div-04">
<h1 class="login-h1-01">여행의 모든 순간을<br/>함께하세요</h1>
<p class="login-p-01">새로운 경험과 추억이 기다리고 있습니다.</p>
</div>
</div>
<div class="auth-form-column">
<div class="mb-8">
<h2 class="login-h2-01">로그인</h2>
<p class="calendar-add-event-span-02">계정에 로그인하여 서비스를 이용하세요.</p>
</div>
<form class="login-form-01" action="/login" method="post">
<label class="fx-group-col-gap2">
<span class="login-span-02">
                            이메일
                            <span class="text-danger">*</span>
</span>
<div class="is-relative">
<div class="login-div-05">
<span class="icon-ms-20">mail</span>
</div>
<input class="signup-input-solid" placeholder="name@example.com" type="email" name="email" value=""/>
</div>
</label>
<label class="fx-group-col-gap2">
<div class="login-div-06">
<span class="login-span-02">
                                비밀번호
                                <span class="text-danger">*</span>
</span>
</div>
<div class="is-relative">
<div class="login-div-05">
<span class="icon-ms-20">lock</span>
</div>
<input class="signup-input-solid" placeholder="비밀번호를 입력하세요" type="password" name="password" value=""/>
</div>
</label>
<div class="login-div-07" style="display: none;">
<span class="icon-ms-sm-red-600">error</span>
<p class="login-p-02">이메일 또는 비밀번호가 올바르지 않습니다.</p>
</div>

<button class="login-button-01" type="submit">
<span>로그인</span>
<span class="icon-ms-sm">arrow_forward</span>
</button>
</form>

<div class="fx-group-col-gap2" style="margin-top: 1px; display: flex; flex-direction: column; gap: 1px;">
    <!-- 네이버 로그인 (Green) -->
    <a href="#" onclick="loginWithNaver(event)" class="login-button-01" style="background-color: #03C75A; color: #FFFFFF; text-decoration: none; display: flex; align-items: center; justify-content: center; border: none; height: 50px; border-radius: 8px;">
        <span style="font-weight: bold; font-size: 1.1rem; margin-right: 8px;">N</span>
        <span style="font-weight: bold;">네이버 로그인</span>
    </a>

    <!-- 카카오 로그인 (Yellow) -->
    <a href="#" onclick="loginWithKakao(event)" class="login-button-01" style="background-color: #FEE500; color: #191919; text-decoration: none; display: flex; align-items: center; justify-content: center; border: none; height: 50px; border-radius: 8px; margin-bottom: 8px; width: 100%;">
        <span class="icon-ms-sm" style="margin-right: 8px;">chat</span>
        <span style="font-weight: bold;">카카오 로그인</span>
    </a>

    <!-- 네이버 SDK 에러 방지용 표준 ID 요소 (보이지 않음) -->
    <div id="naverIdLogin" style="display:none;">
        <div id="naverIdLogin_loginButton" style="display:none;"></div>
    </div>

    <!-- 구글 로그인 (이중 방어: 투명 오버레이 + 백업 onclick) -->
    <a href="javascript:void(0)" onclick="loginWithGoogle(event)" class="login-button-01" style="position: relative; background-color: #FFFFFF; color: #191919; text-decoration: none; display: flex; align-items: center; justify-content: center; border: 1px solid #DADCE0; height: 50px; border-radius: 8px; width: 100%; overflow: hidden;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" style="margin-right: 8px;">
            <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24s8.955,20,20,20s20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
            <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
            <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
            <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
        </svg>
        <span style="font-weight: bold;">구글 로그인</span>
        <div id="googleLoginBtn" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.02; cursor: pointer; z-index: 10;"></div>
    </a>
</div>

<div class="login-div-08">
<p class="calendar-add-event-span-02">
                        계정이 없으신가요? 
                        <a class="login-a-02" href="/join-form">회원가입 하기</a>
</p>
</div>
</div>
</div>
</main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  
  <!-- SNS SDKs -->
  <script src="https://developers.kakao.com/sdk/js/kakao.min.js"></script>
  <script src="https://static.nid.naver.com/js/naveridlogin_js_sdk_2.0.2.js" charset="utf-8"></script>
  <script src="https://accounts.google.com/gsi/client" async defer></script>

  <script>
    const KAKAO_JS_KEY = '{{model.kakaoJsAppKey}}'.trim();
    const NAVER_CLIENT_ID = '{{model.naverClientId}}'.trim();
    const GOOGLE_CLIENT_ID = '{{model.googleClientId}}'.trim();

    /* ===== [1] 네이버 콜백 처리 (최우선 실행) ===== */
    (function handleNaverCallback() {
      if (window.location.hash.includes("access_token")) {
        document.documentElement.style.display = 'none'; // 팝업 내 우리 사이트 노출 방지
        
        const process = () => {
          if (typeof naver === 'undefined') { setTimeout(process, 50); return; }
          const naverLogin = new naver.LoginWithNaverId({ clientId: NAVER_CLIENT_ID });
          naverLogin.init();
          naverLogin.getLoginStatus(function(status) {
            if (status) {
              const user = naverLogin.user;
              const url = `/auth/naver/callback?providerId=${user.id}&nickname=${encodeURIComponent(user.nickname || 'Guest')}&email=${user.email || ''}`;
              if (window.opener && window.opener !== window) {
                window.opener.location.href = url;
                window.close();
              } else {
                window.location.href = url;
              }
            }
          });
        };
        process();
      }
    })();

    document.addEventListener('DOMContentLoaded', function() {
      // 카카오 SDK 초기화
      if (typeof Kakao !== 'undefined' && KAKAO_JS_KEY && !Kakao.isInitialized()) {
        Kakao.init(KAKAO_JS_KEY);
      }

      // 구글 버튼 초기화 및 렌더링
      const checkGoogle = setInterval(() => {
        if (typeof google !== 'undefined' && google.accounts) {
          clearInterval(checkGoogle);
          const target = document.getElementById("googleLoginBtn");
          if (target) {
            google.accounts.id.initialize({
              client_id: GOOGLE_CLIENT_ID,
              callback: handleGoogleResponse,
              use_fedcm_for_prompt: false
            });
            google.accounts.id.renderButton(target, { theme: "outline", size: "large", width: target.offsetWidth });
          }
        }
      }, 100);

      // 중복 로그인 알림 처리
      handleForcedLogoutAlert();
    });

    /* ===== [2] 소셜 로그인 실행 함수들 ===== */
    function loginWithNaver(event) {
      if (event) event.preventDefault();
      const state = Math.random().toString(36).substr(2, 11);
      const url = `https://nid.naver.com/oauth2.0/authorize?response_type=token&client_id=${NAVER_CLIENT_ID}&redirect_uri=${encodeURIComponent(window.location.origin + "/login-form")}&state=${state}`;
      window.open(url, "naverLogin", "width=500,height=600");
    }

    function loginWithKakao(event) {
      if (event) event.preventDefault();
      if (typeof Kakao === 'undefined' || !Kakao.isInitialized()) return;

      Kakao.Auth.login({
        throughTalk: false,
        success: function() {
          Kakao.API.request({
            url: '/v2/user/me',
            success: function(res) {
              const id = res.id;
              const nickname = (res.properties && res.properties.nickname) ? res.properties.nickname : 'Guest';
              const email = (res.kakao_account && res.kakao_account.email) ? res.kakao_account.email : '';
              window.location.href = `/auth/kakao/callback?providerId=${id}&nickname=${encodeURIComponent(nickname)}&email=${email}`;
            }
          });
        }
      });
    }

    function loginWithGoogle(event) {
      if (event) event.preventDefault();
      google.accounts.id.prompt();
    }

    function handleGoogleResponse(response) {
      const payload = JSON.parse(decodeURIComponent(atob(response.credential.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join('')));
      window.location.href = `/auth/google/callback?providerId=${payload.sub}&nickname=${encodeURIComponent(payload.name)}&email=${payload.email}`;
    }

    function handleForcedLogoutAlert() {
      const params = new URLSearchParams(window.location.search);
      if (params.get('forcedLogout') === 'concurrent') {
        alert('다른 기기에서 로그인되어 로그아웃되었습니다.');
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    }
  </script>
  
  {{>partials/scripts}}
</body>
</html>
