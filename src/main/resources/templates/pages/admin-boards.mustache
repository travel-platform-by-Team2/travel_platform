<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 게시글 관리</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{>partials/admin-sidebar}}

        <section class="admin-content">
          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">게시글 관리</h1>
              <p class="admin-page-subtitle">
                커뮤니티의 모든 게시글을 관리하고 모니터링하는 관리자 화면입니다.
              </p>
            </div>
          </div>

          <section class="admin-panel">
            <div class="admin-board-summary">
              <div class="admin-board-summary__left">
                <div class="admin-board-hero__count">
                  <span class="admin-board-hero__count-label">전체 게시글</span>
                  <strong class="admin-board-hero__count-value">{{model.allCount}}</strong>
                </div>
              </div>

              <div class="admin-board-summary__right">
                <a class="admin-board-reset" href="/admin/boards">
                  <span class="material-symbols-outlined">restart_alt</span>
                  필터 초기화
                </a>
              </div>
            </div>

            <div class="admin-board-hero">
              <div class="admin-board-hero__backdrop"></div>

              <div class="admin-board-hero__tab-row">
                <div class="admin-board-hero__tabs admin-tab-shell" aria-label="게시글 카테고리 필터">
                <a href="/admin/boards?category=all{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                   class="admin-tab-button cat-all {{#model.allCategoryTab}}is-active-tab{{/model.allCategoryTab}}"
                   style="flex:1 1 0; min-width:120px; text-align:center;">
                   전체
                 </a>

                <a href="/admin/boards?category=tips{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                   class="admin-tab-button cat-tips {{#model.isTips}}is-active-tab{{/model.isTips}}"
                   style="flex:1 1 0; min-width:120px; text-align:center;">
                  여행 팁
                </a>

                <a href="/admin/boards?category=plan{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                   class="admin-tab-button cat-plan {{#model.isPlan}}is-active-tab{{/model.isPlan}}"
                   style="flex:1 1 0; min-width:120px; text-align:center;">
                  여행 계획
                </a>

                <a href="/admin/boards?category=food{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                   class="admin-tab-button cat-food {{#model.isFood}}is-active-tab{{/model.isFood}}"
                   style="flex:1 1 0; min-width:120px; text-align:center;">
                  맛집/카페
                </a>

                <a href="/admin/boards?category=review{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                   class="admin-tab-button cat-review {{#model.isReview}}is-active-tab{{/model.isReview}}"
                   style="flex:1 1 0; min-width:120px; text-align:center;">
                  숙소 후기
                </a>

                <a href="/admin/boards?category=qna{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                   class="admin-tab-button cat-qna {{#model.isQna}}is-active-tab{{/model.isQna}}"
                   style="flex:1 1 0; min-width:120px; text-align:center;">
                  질문/답변
                </a>
                </div>
              </div>

              <div class="admin-board-hero__controls">
                <form action="/admin/boards" method="get" class="admin-search-wrap admin-board-search">
                  <span class="material-symbols-outlined">search</span>
                  <input type="hidden" name="category" value="{{model.allCategory}}">
                  <input type="hidden" name="sort" value="{{model.sort}}">
                  <input
                    type="text"
                    name="keyword"
                    value="{{model.keyword}}"
                    placeholder="게시글 검색..."
                    class="admin-board-search__input">
                  <button type="submit" class="admin-search-submit admin-board-search__submit">검색</button>
                </form>

                <div class="admin-board-sort-group">
                  <details class="admin-board-sort-dropdown">
                    <summary class="admin-board-sort-button">
                      {{model.sortFieldLabel}}
                      <span class="material-symbols-outlined">expand_more</span>
                    </summary>
                    <div class="community-sort-menu admin-board-sort-menu">
                      <a class="community-sort-option"
                         href="/admin/boards?sort={{model.viewField}}{{#model.allCategory}}&category={{model.allCategory}}{{/model.allCategory}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}">조회순</a>
                      <a class="community-sort-option"
                         href="/admin/boards?sort={{model.likesField}}{{#model.allCategory}}&category={{model.allCategory}}{{/model.allCategory}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}">좋아요순</a>
                      <a class="community-sort-option"
                         href="/admin/boards?sort={{model.dateField}}{{#model.allCategory}}&category={{model.allCategory}}{{/model.allCategory}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}">날짜순</a>
                    </div>
                  </details>

                  <a href="/admin/boards?sort={{model.toggleDirectionSort}}{{#model.allCategory}}&category={{model.allCategory}}{{/model.allCategory}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}"
                     class="admin-filter-button admin-board-sort-toggle">
                    {{model.sortDirectionLabel}}
                  </a>
                </div>
              </div>
            </div>

            <div class="admin-table-wrap">
              <table class="table admin-table">
                <thead>
                  <tr>
                    <th>No</th>
                    <th>제목</th>
                    <th>작성자</th>
                    <th>작성일</th>
                    <th class="text-center">조회수</th>
                    <th class="text-end">관리</th>
                  </tr>
                </thead>
                <tbody>
                  {{#model.boards}}
                  <tr>
                    <td>
                      <span class="admin-category-badge {{categoryClass}}">{{category}}</span>
                    </td>
                    <td>
                      <a href="/boards/{{id}}" class="admin-name admin-title-link">{{title}}</a>
                    </td>
                    <td>{{userName}}</td>
                    <td>{{startDate}}</td>
                    <td class="text-center">{{viewCount}}</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  {{/model.boards}}

                  {{^model.boards}}
                  <tr>
                    <td colspan="6" class="text-center">게시글이 없습니다.</td>
                  </tr>
                  {{/model.boards}}
                </tbody>
              </table>
            </div>

            <div class="admin-panel__footer">
              <div class="admin-pagination">
                {{#model.prevPage}}
                <a class="admin-page-button"
                   href="/admin/boards?page={{model.prevPage}}{{#model.allCategory}}&category={{model.allCategory}}{{/model.allCategory}}{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}">
                  <span class="material-symbols-outlined">chevron_left</span>
                </a>
                {{/model.prevPage}}

                {{#model.pageItems}}
                  {{#current}}
                  <button class="admin-page-button is-active-page" type="button">
                    {{displayNumber}}
                  </button>
                  {{/current}}

                  {{^current}}
                  <a class="admin-page-button"
                     href="/admin/boards?page={{page}}{{#selectCategory}}&category={{selectCategory}}{{/selectCategory}}{{#sort}}&sort={{sort}}{{/sort}}{{#keyword}}&keyword={{keyword}}{{/keyword}}">
                    {{displayNumber}}
                  </a>
                  {{/current}}
                {{/model.pageItems}}

                {{#model.nextPage}}
                <a class="admin-page-button"
                   href="/admin/boards?page={{model.nextPage}}{{#model.allCategory}}&category={{model.allCategory}}{{/model.allCategory}}{{#model.sort}}&sort={{model.sort}}{{/model.sort}}{{#model.keyword}}&keyword={{model.keyword}}{{/model.keyword}}">
                  <span class="material-symbols-outlined">chevron_right</span>
                </a>
                {{/model.nextPage}}
              </div>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{>partials/admin-page-scripts}}
</body>
</html>
