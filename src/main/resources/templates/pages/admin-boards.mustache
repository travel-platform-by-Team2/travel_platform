<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 게시글 관리</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{>partials/admin-sidebar}}

        <section class="admin-content">
          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">게시글 관리</h1>
              <p class="admin-page-subtitle">커뮤니티의 모든 게시글을 관리하고 모니터링하는 관리자 화면을 현재 공용 템플릿 구조에 맞게 정리했습니다.</p>
            </div>
          </div>

          <div class="admin-metric-grid">
            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div>
                  <span class="admin-metric-label">전체 게시글</span>
                  <p class="admin-metric-value">{{totalCount}}</p>
                </div>
              </div>
            </article>
          </div>

          <section class="admin-panel">
            <div class="admin-toolbar">
              <div class="admin-tab-shell" aria-label="게시글 카테고리 필터">
                <a href="/admin/boards" class="admin-tab-button cat-all {{^selectCategory}}is-active-tab{{/selectCategory}}">전체</a>
                <a href="/admin/boards?category=tips" class="admin-tab-button cat-tips {{#isTips}}is-active-tab{{/isTips}}">여행 팁</a>
                <a href="/admin/boards?category=plan" class="admin-tab-button cat-plan {{#isPlan}}is-active-tab{{/isPlan}}">여행 계획</a>
                <a href="/admin/boards?category=food" class="admin-tab-button cat-food {{#isFood}}is-active-tab{{/isFood}}">맛집/카페</a>
                <a href="/admin/boards?category=review" class="admin-tab-button cat-review {{#isReview}}is-active-tab{{/isReview}}">숙소 후기</a>
                <a href="/admin/boards?category=qna" class="admin-tab-button cat-qna {{#isQna}}is-active-tab{{/isQna}}">질문/답변</a>
            </div>

              <div class="admin-search-group">
                <div class="admin-search-wrap">
                  <span class="material-symbols-outlined">search</span>
                  <input class="form-control admin-search-field" type="text" placeholder="게시글 검색...">
                </div>
              </div>
            </div>

            <div class="admin-table-wrap">
              <table class="table admin-table">
                <thead>
                  <tr>
                    <th>No</th>
                    <th>제목</th>
                    <th>작성자</th>
                    <th>작성일</th>
                    <th class="text-center">조회수</th>
                    <th class="text-end">관리</th>
                  </tr>
                </thead>
                <tbody>
                {{#model.boards}}
                  <tr>
                    <td><span class="admin-category-badge {{categoryClass}}">{{category}}</span></td>
                    <td><p class="admin-name">{{title}}</p></td>
                    <td>{{userName}}</td>
                    <td>{{startDate}}</td>
                    <td class="text-center">{{viewCount}}</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  {{/model.boards}}

                  {{^model.boards}}
                  <tr>
                    <td colspan="6" class="text-center">게시글이 없습니다.</td>
                  </tr>
                  {{/model.boards}}
                </tbody>
              </table>
            </div>

            <div class="admin-panel__footer">
              <div class="admin-pagination">
    {{#model.prevPage}}
  <a class="admin-page-button" href="/admin/boards?page={{model.prevPage}}{{#selectedCategory}}&category={{selectedCategory}}{{/selectedCategory}}">
    <span class="material-symbols-outlined">chevron_left</span>
  </a>
  {{/model.prevPage}}

  {{#model.pageItems}}
    {{#current}}
    <button class="admin-page-button is-active-page" type="button">
      {{displayNumber}}
    </button>
    {{/current}}

    {{^current}}
    <a class="admin-page-button"
       href="/admin/boards?page={{page}}{{#selectedCategory}}&category={{selectedCategory}}{{/selectedCategory}}">
      {{displayNumber}}
    </a>
    {{/current}}
  {{/model.pageItems}}

  {{#model.nextPage}}
  <a class="admin-page-button" href="/admin/boards?page={{model.nextPage}}{{#selectedCategory}}&category={{selectedCategory}}{{/selectedCategory}}">
    <span class="material-symbols-outlined">chevron_right</span>
  </a>
  {{/model.nextPage}}
              </div>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{>partials/admin-page-scripts}}
</body>
</html>
