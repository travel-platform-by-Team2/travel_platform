<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 게시글 관리</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{>partials/admin-sidebar}}

        <section class="admin-content">
          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">게시글 관리</h1>
              <p class="admin-page-subtitle">커뮤니티의 모든 게시글을 관리하고 모니터링하는 관리자 화면을 현재 공용 템플릿 구조에 맞게 정리했습니다.</p>
            </div>
          </div>

          <div class="admin-metric-grid">
            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div>
                  <span class="admin-metric-label">전체 게시글</span>
                  <p class="admin-metric-value">1,284</p>
                </div>
              </div>
            </article>
          </div>

          <section class="admin-panel">
            <div class="admin-toolbar">
              <div class="admin-tab-shell" aria-label="게시글 카테고리 필터">
                <button class="admin-tab-button is-active-tab" type="button">전체</button>
                <button class="admin-tab-button" type="button">여행 팁</button>
                <button class="admin-tab-button" type="button">여행 계획</button>
                <button class="admin-tab-button" type="button">맛집/카페</button>
                <button class="admin-tab-button" type="button">숙소 후기</button>
                <button class="admin-tab-button" type="button">질문/답변</button>
              </div>

              <div class="admin-search-group">
                <div class="admin-search-wrap">
                  <span class="material-symbols-outlined">search</span>
                  <input class="form-control admin-search-field" type="text" placeholder="게시글 검색...">
                </div>
              </div>
            </div>

            <div class="admin-table-wrap">
              <table class="table admin-table">
                <thead>
                  <tr>
                    <th>No</th>
                    <th>제목</th>
                    <th>작성자</th>
                    <th>작성일</th>
                    <th class="text-center">조회수</th>
                    <th class="text-end">관리</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><span class="admin-category-badge category-blue">여행 팁</span></td>
                    <td><p class="admin-name">유럽 배낭여행 꿀팁 BEST 10</p></td>
                    <td>김철수</td>
                    <td>2023-10-24</td>
                    <td class="text-center">1,420</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td><span class="admin-category-badge category-orange">맛집/카페</span></td>
                    <td><p class="admin-name">제주도 현지인만 아는 숨은 맛집 공개</p></td>
                    <td>이영희</td>
                    <td>2023-10-23</td>
                    <td class="text-center">892</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td><span class="admin-category-badge category-purple">질문/답변</span></td>
                    <td><p class="admin-name">일본 비자 신청 관련 질문드려요</p></td>
                    <td>박민수</td>
                    <td>2023-10-23</td>
                    <td class="text-center">156</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td><span class="admin-category-badge category-green">숙소 후기</span></td>
                    <td><p class="admin-name">강릉 오션뷰 펜션 솔직 방문기</p></td>
                    <td>최수지</td>
                    <td>2023-10-22</td>
                    <td class="text-center">2,104</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td><span class="admin-category-badge category-indigo">여행 계획</span></td>
                    <td><p class="admin-name">3박 4일 도쿄 쇼핑 여행 일정 공유</p></td>
                    <td>정우성</td>
                    <td>2023-10-21</td>
                    <td class="text-center">543</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="admin-panel__footer">
              <p class="admin-pagination-note">총 1,284개 중 1-20 표시</p>
              <div class="admin-pagination">
                <button class="admin-page-button" type="button" disabled>
                  <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button class="admin-page-button is-active-page" type="button">1</button>
                <button class="admin-page-button" type="button">2</button>
                <button class="admin-page-button" type="button">3</button>
                <span class="text-muted">...</span>
                <button class="admin-page-button" type="button">65</button>
                <button class="admin-page-button" type="button">
                  <span class="material-symbols-outlined">chevron_right</span>
                </button>
              </div>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{>partials/admin-page-scripts}}
</body>
</html>
