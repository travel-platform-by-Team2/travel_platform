<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 게시글 관리</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{>partials/admin-sidebar}}

        <section class="admin-content">

          <!-- 수정: model 안에서만 전체 렌더링 -->
          {{#model}}

          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">게시글 관리</h1>
              <p class="admin-page-subtitle">
                커뮤니티의 모든 게시글을 관리하고 모니터링하는 관리자 화면을 현재 공용 템플릿 구조에 맞게 정리했습니다.
              </p>
            </div>
          </div>

          <div class="admin-metric-grid">
            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div>
                  <span class="admin-metric-label">전체 게시글</span>
                  <p class="admin-metric-value">{{allCount}}</p>
                </div>
              </div>
            </article>
          </div>

          <section class="admin-panel">
            <div class="admin-toolbar">
              <div class="admin-tab-shell" aria-label="게시글 카테고리 필터">
                <!-- 수정: 탭 링크에서 keyword 유지 기능 제거 -->
                <a href="/admin/boards"
                   class="admin-tab-button cat-all {{^category}}is-active-tab{{/category}}">
                  전체
                </a>

                <a href="/admin/boards?category=tips"
                   class="admin-tab-button cat-tips {{#isTips}}is-active-tab{{/isTips}}">
                  여행 팁
                </a>

                <a href="/admin/boards?category=plan"
                   class="admin-tab-button cat-plan {{#isPlan}}is-active-tab{{/isPlan}}">
                  여행 계획
                </a>

                <a href="/admin/boards?category=food"
                   class="admin-tab-button cat-food {{#isFood}}is-active-tab{{/isFood}}">
                  맛집/카페
                </a>

                <a href="/admin/boards?category=review"
                   class="admin-tab-button cat-review {{#isReview}}is-active-tab{{/isReview}}">
                  숙소 후기
                </a>

                <a href="/admin/boards?category=qna"
                   class="admin-tab-button cat-qna {{#isQna}}is-active-tab{{/isQna}}">
                  질문/답변
                </a>
              </div>

              <div class="admin-search-group">
                <form action="/admin/boards" method="get" class="admin-search-wrap">
                  <span class="material-symbols-outlined">search</span>

                  <!-- 수정: keyword 출력 자체가 계속 터지면 value도 일단 제거 -->
                  <input
                    class="form-control admin-search-field"
                    type="text"
                    name="keyword"
                    placeholder="게시글 검색...">

                  <!-- 수정: hidden category 제거 -->
                </form>
              </div>
            </div>

            <div class="admin-table-wrap">
              <table class="table admin-table">
                <thead>
                  <tr>
                    <th>No</th>
                    <th>제목</th>
                    <th>작성자</th>
                    <th>작성일</th>
                    <th class="text-center">조회수</th>
                    <th class="text-end">관리</th>
                  </tr>
                </thead>
                <tbody>
                  {{#boards}}
                  <tr>
                    <td>
                      <span class="admin-category-badge {{categoryClass}}">{{category}}</span>
                    </td>
                    <td>
                      <a href="/boards/{{id}}" class="admin-name admin-title-link">{{title}}</a>
                    </td>
                    <td>{{userName}}</td>
                    <td>{{startDate}}</td>
                    <td class="text-center">{{viewCount}}</td>
                    <td class="text-end">
                      <div class="admin-action-menu" data-admin-action-menu>
                        {{>partials/admin-board-action-menu}}
                      </div>
                    </td>
                  </tr>
                  {{/boards}}

                  {{^boards}}
                  <tr>
                    <td colspan="6" class="text-center">게시글이 없습니다.</td>
                  </tr>
                  {{/boards}}
                </tbody>
              </table>
            </div>

            <div class="admin-panel__footer">
              <div class="admin-pagination">

                {{#prevPage}}
                <!-- 수정: prevPage에서 category/keyword 유지 제거 -->
                <a class="admin-page-button" href="/admin/boards?page={{prevPage}}">
                  <span class="material-symbols-outlined">chevron_left</span>
                </a>
                {{/prevPage}}

                {{#pageItems}}
                  {{#current}}
                  <button class="admin-page-button is-active-page" type="button">
                    {{displayNumber}}
                  </button>
                  {{/current}}

                  {{^current}}
                  <!-- 수정: pageItems 안에서는 pageItem 필드만 사용 -->
                  <a class="admin-page-button" href="/admin/boards?page={{page}}">
                    {{displayNumber}}
                  </a>
                  {{/current}}
                {{/pageItems}}

                {{#nextPage}}
                <!-- 수정: nextPage에서도 category/keyword 유지 제거 -->
                <a class="admin-page-button" href="/admin/boards?page={{nextPage}}">
                  <span class="material-symbols-outlined">chevron_right</span>
                </a>
                {{/nextPage}}

              </div>
            </div>
          </section>

          {{/model}}

        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{>partials/admin-page-scripts}}
</body>
</html>