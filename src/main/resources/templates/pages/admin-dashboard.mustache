<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 대시보드</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{#model}}
        {{>partials/admin-sidebar}}
        {{/model}}

        <section class="admin-content">
          <div class="admin-breadcrumb">
            <span>홈</span>
            <span class="material-symbols-outlined">chevron_right</span>
            <span>대시보드</span>
          </div>

          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">관리자 홈 요약</h1>
              <p class="admin-page-subtitle">사용자와 커뮤니티 현황을 빠르게 확인할 수 있도록 실데이터 기반 대시보드로 정리했습니다.</p>
            </div>
            <div class="admin-summary-note">
              <span class="material-symbols-outlined">monitoring</span>
              <span>유저/게시글 현황 요약</span>
            </div>
          </div>

          <div class="admin-metric-grid">
            {{#model.metrics}}
            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div class="admin-metric-icon {{iconClass}}">
                  <span class="material-symbols-outlined">{{icon}}</span>
                </div>
              </div>
              <span class="admin-metric-label">{{label}}</span>
              <p class="admin-metric-value">{{valueLabel}}</p>
              <p class="admin-metric-helper">{{helperLabel}}</p>
            </article>
            {{/model.metrics}}
          </div>

          <div class="admin-grid-2 admin-grid-2--charts">
            <section class="admin-panel">
              <div class="admin-panel__header">
                <div>
                  <h2 class="admin-panel__title">
                    <span class="material-symbols-outlined">donut_large</span>
                    <span>사용자 상태 비율</span>
                  </h2>
                  <p class="admin-panel__subtitle">활성/비활성 사용자 분포</p>
                </div>
              </div>

              <div class="admin-panel__body">
                <div class="admin-chart-list">
                  {{#model.userStatusItems}}
                  <article class="admin-chart-row">
                    <div class="admin-chart-row__head">
                      <div class="admin-chart-row__title">
                        <span class="admin-status-badge {{badgeClass}}">{{label}}</span>
                      </div>
                      <div class="admin-chart-row__meta">
                        <span>{{countLabel}}</span>
                        <span>{{percentLabel}}</span>
                      </div>
                    </div>
                    <div class="admin-chart-track">
                      <div class="admin-chart-fill {{barClass}}" style="width: {{barWidth}}%;"></div>
                    </div>
                  </article>
                  {{/model.userStatusItems}}
                </div>
              </div>
            </section>

            <section class="admin-panel">
              <div class="admin-panel__header">
                <div>
                  <h2 class="admin-panel__title">
                    <span class="material-symbols-outlined">stacked_bar_chart</span>
                    <span>게시글 카테고리 분포</span>
                  </h2>
                  <p class="admin-panel__subtitle">커뮤니티 전체 글 기준 점유율</p>
                </div>
              </div>

              <div class="admin-panel__body">
                <div class="admin-chart-list">
                  {{#model.boardCategoryItems}}
                  <article class="admin-chart-row">
                    <div class="admin-chart-row__head">
                      <div class="admin-chart-row__title">
                        <span class="{{badgeClass}}">{{label}}</span>
                      </div>
                      <div class="admin-chart-row__meta">
                        <span>{{countLabel}}</span>
                        <span>{{percentLabel}}</span>
                      </div>
                    </div>
                    <div class="admin-chart-track">
                      <div class="admin-chart-fill {{barClass}}" style="width: {{barWidth}}%;"></div>
                    </div>
                  </article>
                  {{/model.boardCategoryItems}}
                </div>
              </div>
            </section>
          </div>

          <div class="admin-grid-2 admin-grid-2--feeds">
            <section class="admin-panel">
              <div class="admin-panel__header">
                <h2 class="admin-panel__title">
                  <span class="material-symbols-outlined">group</span>
                  <span>최근 유저 리스트</span>
                </h2>
                <a class="admin-link" href="/admin/users">전체보기</a>
              </div>

              <div class="admin-panel__body">
                {{#model.hasRecentUsers}}
                <div class="admin-feed-list">
                  {{#model.recentUsers}}
                  <article class="admin-feed-item">
                    <div class="admin-feed-icon">
                      <span class="material-symbols-outlined">person</span>
                    </div>
                    <div class="flex-grow-1 min-w-0">
                      <p class="admin-feed-title">{{username}}</p>
                      <p class="admin-feed-meta">
                        <span class="admin-status-badge {{statusClass}}">{{statusText}}</span>
                        <span>•</span>
                        <span>가입일: {{createdAtLabel}}</span>
                      </p>
                    </div>
                  </article>
                  {{/model.recentUsers}}
                </div>
                {{/model.hasRecentUsers}}

                {{^model.hasRecentUsers}}
                <div class="admin-empty-state">
                  <span class="material-symbols-outlined">group_off</span>
                  <p>표시할 최근 유저가 없습니다.</p>
                </div>
                {{/model.hasRecentUsers}}
              </div>
            </section>

            <section class="admin-panel">
              <div class="admin-panel__header">
                <h2 class="admin-panel__title">
                  <span class="material-symbols-outlined">forum</span>
                  <span>최근 게시글 리스트</span>
                </h2>
                <a class="admin-link" href="/admin/boards">전체보기</a>
              </div>

              <div class="admin-panel__body">
                {{#model.hasRecentBoards}}
                <div class="admin-feed-list">
                  {{#model.recentBoards}}
                  <article class="admin-feed-item">
                    <div class="admin-feed-icon">
                      <span class="material-symbols-outlined">article</span>
                    </div>
                    <div class="flex-grow-1 min-w-0">
                      <p class="admin-feed-title">{{title}}</p>
                      <p class="admin-feed-meta">
                        <span>작성자: {{userName}}</span>
                        <span>•</span>
                        <span>{{createdAtLabel}}</span>
                      </p>
                    </div>
                  </article>
                  {{/model.recentBoards}}
                </div>
                {{/model.hasRecentBoards}}

                {{^model.hasRecentBoards}}
                <div class="admin-empty-state">
                  <span class="material-symbols-outlined">article_person</span>
                  <p>표시할 최근 게시글이 없습니다.</p>
                </div>
                {{/model.hasRecentBoards}}
              </div>
            </section>
          </div>
        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{>partials/admin-page-scripts}}
</body>
</html>
