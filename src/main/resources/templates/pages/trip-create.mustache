</div>
</div>
</div>
</div>
<div class="trip-plan-create-div-09">
<button class="trip-plan-create-button-05">
                    취소
                </button>
<button class="trip-plan-create-button-06">
                    계획 생성하기
                </button>
</div>
</div>
</main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
