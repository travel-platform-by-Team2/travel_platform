  <script>
  // 1. '누구와 함께하나?' 버튼 클릭 이벤트 로직
  const whoWithButtons = document.querySelectorAll('.feature-tile, .trip-plan-create-button-01');
  whoWithButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      e.preventDefault(); 
      
      // 모든 버튼 스타일 초기화
      whoWithButtons.forEach(btn => {
          btn.style.border = '';
          btn.style.backgroundColor = '';
          btn.style.color = '';
      });
      
      // 클릭된 버튼에 시각적 효과 (파란색 테두리와 연한 배경)
      this.style.border = '2px solid #1152D4';
      this.style.backgroundColor = '#f1f5f9';
      this.style.color = '#1152D4';

      const selection = this.querySelector('span:last-child').innerText;
      document.getElementById('whoWithInput').value = selection;
    });
  });

  // 2. 달력 날짜 클릭 및 범위 선택 로직
  let startDate = null;
  let endDate = null;

  // 화면에 있는 두 개의 달력 영역(10월, 11월)을 각각 찾아서 날짜 데이터(data-date)를 부여합니다.
  const calendarPanes = document.querySelectorAll('.layout-narrow-fill, .calendar-preview-pane');
  
  calendarPanes.forEach(pane => {
      // "2023년 10월" 같은 텍스트에서 연도와 월 추출
      const yearMonthText = pane.querySelector('.text-main-lg-bold').innerText;
      const match = yearMonthText.match(/(\d+)년\s*(\d+)월/);
      if (!match) return;
      
      const year = match[1];
      const month = match[2].padStart(2, '0');
      
      // 달력의 실제 날짜 버튼들만 선택 (이전/다음 달 버튼 제외)
      const buttons = pane.querySelectorAll('.calendar-chip-btn, .chip-primary-soft, .trip-plan-create-button-03, .trip-plan-create-button-04');
      
      buttons.forEach(button => {
          button.setAttribute('type', 'button'); // submit 방지
          
          const day = button.innerText.trim();
          if (day) {
              const fullDate = `${year}-${month}-${day.padStart(2, '0')}`;
              button.setAttribute('data-date', fullDate);
              
              button.addEventListener('click', function(e) {
                  e.preventDefault();
                  
                  const clickedDate = this.getAttribute('data-date');
                  
                  if (!startDate || (startDate && endDate)) {
                      // 처음 클릭하거나, 이미 범위가 선택된 상태에서 다시 클릭하면 새로운 시작일로 지정
                      startDate = clickedDate;
                      endDate = null;
                  } else {
                      // 두 번째 클릭: 종료일 지정 (시작일보다 앞선 날짜를 클릭하면 서로 바꿈)
                      if (clickedDate < startDate) {
                          endDate = startDate;
                          startDate = clickedDate;
                      } else {
                          endDate = clickedDate;
                      }
                  }
                  
                  // hidden input 업데이트
                  document.getElementById('startDateInput').value = startDate;
                  document.getElementById('endDateInput').value = endDate || '';
                  
                  updateCalendarUI(); // 화면 갱신
              });
          }
      });
  });

  // 달력 UI 갱신 함수 (선택된 날짜와 범위 색상 칠하기)
  function updateCalendarUI() {
      const allButtons = Array.from(document.querySelectorAll('button[data-date]'));

      // 범위 내의 날짜들만 필터링 (시작일과 종료일 제외)
      const rangeButtons = allButtons.filter(btn => {
          const d = btn.getAttribute('data-date');
          return startDate && endDate && d > startDate && d < endDate;
      });

      // 정렬 (날짜 순)
      rangeButtons.sort((a, b) => a.getAttribute('data-date').localeCompare(b.getAttribute('data-date')));

      allButtons.forEach(btn => {
          const d = btn.getAttribute('data-date');

          // 1. 기본 스타일로 초기화
          btn.style.backgroundColor = '';
          btn.style.color = '';
          btn.style.borderRadius = '45px'; // 기본적으로 약간 둥근 직사각형 유지
          
          // 2. 시작일 또는 종료일인 경우 (진한 파란색)
          if (d === startDate || d === endDate) {
              btn.style.backgroundColor = '#1152D4';
              btn.style.color = 'white';
              btn.style.borderRadius = '12px'; // 너무 타원형이지 않게 조정
          } 
          // 3. 시작일과 종료일 사이의 범위인 경우 (연한 바 형태)
          else if (startDate && endDate && d > startDate && d < endDate) {
              btn.style.backgroundColor = '#f1f5f9'; 
              btn.style.color = '#333';

              // 범위가 하루뿐인 경우 (양쪽 모두 둥글게)
              if (rangeButtons.length === 1) {
                  btn.style.borderRadius = '12px';
              } 
              // 범위의 첫 번째 날인 경우 (왼쪽만 둥글게)
              else if (btn === rangeButtons[0]) {
                  btn.style.borderRadius = '12px 0 0 12px';
              } 
              // 범위의 마지막 날인 경우 (오른쪽만 둥글게)
              else if (btn === rangeButtons[rangeButtons.length - 1]) {
                  btn.style.borderRadius = '0 12px 12px 0';
              } 
              // 완전 중간 날짜인 경우 (곡선 없이 직사각형)
              else {
                  btn.style.borderRadius = '0'; 
              }
          }
      });
  }  </script>
