<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Community Post Detail</title>
  {{>partials/head-assets}}
  <!--버튼 좋아요 css -->
  <style>
    #board-like-btn.is-liked { border-color:#ec4899; color:#ec4899; }
    #board-like-btn.is-liked #board-like-icon { color:#ec4899; font-variation-settings:"FILL" 1; }
  </style>
</head>

<body class="page-body">
  {{>partials/header}}

  <div class="page-topbar">
    <div class="container-7xl-px6"></div>
  </div>

  <main class="page-main-wrap-5xl">

    <div class="mb-6">
      <a class="community-detail-button-01" href="/boards">
        <span class="icon-ms-lg">arrow_back</span>
        <span class="community-detail-span-01">목록으로</span>
      </a>
    </div>

    {{#board}}

    <div class="community-detail-div-01">

      <div class="community-detail-div-02">
        <div class="community-detail-div-03">

          <div class="row-between-center">
            <span class="community-detail-span-02 {{categoryClass}}">
              {{categoryLabel}}
            </span>

            {{#isOwner}}
            <div class="calendar-add-event-div-06">
              <a class="community-detail-button-02" href="/boards/{{id}}/edit">수정</a>

              <form action="/boards/{{id}}/delete" method="post">
                <button class="community-detail-button-03" type="submit">
                  삭제
                </button>
              </form>
            </div>
            {{/isOwner}}
          </div>

          <div>
            <h1 class="community-detail-h1-01">
              {{title}}
            </h1>

            <div class="community-detail-div-04">
              <div class="community-create-div-03">
                <div class="inline-items-gap-2">
                  
                  <span class="community-detail-span-03">
                    {{username}}
                  </span>
                </div>

                <span>{{createdAtDisplay}}</span>
              </div>

              <div class="community-detail-div-06">
                <span class="icon-ms-lg">visibility</span>
                <span>{{viewCount}}</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="p-8">
        <div class="prose-reading-lg">
          <p class="mb-6">
            {{{content}}}
          </p>
        </div>

        <div class="community-detail-div-08">
        {{#likedByMe}}
          <button id="board-like-btn" class="fx-group-chip-outline is-liked" data-board-id="{{id}}">
          <span id="board-like-icon" class="icon-ms-hover-fill-current">favorite</span>
          <span class="fw-medium-500">좋아요 <span id="board-like-count">{{likeCount}}</span></span>
        </button>
        {{/likedByMe}}

          {{^likedByMe}}
            <button id="board-like-btn" class="fx-group-chip-outline" data-board-id="{{id}}">
            <span id="board-like-icon" class="icon-ms-hover-fill-current">favorite_border</span>
            <span class="fw-medium-500">좋아요 <span id="board-like-count">{{likeCount}}</span></span>
         </button>
          {{/likedByMe}}

          <button id="board-share-btn" class="community-detail-button-04" type="button">
            <span class="icon-ms-base">share</span>
            <span class="fw-medium-500">공유하기</span>
          </button>
        </div>
      </div>

    </div>

    <div class="community-detail-div-09">
      <h3 class="section-title-row">
        댓글 <span id="reply-count-value" class="text-primary">{{replyCount}}</span>
      </h3>

      <form id="reply-create-form" action="/boards/{{id}}/replies" method="post" data-board-id="{{id}}">
        <div class="community-detail-div-10">
          

          <div class="flex-fill">
            <textarea
              id="reply-create-content"
              class="community-detail-textarea-01"
              name="content"
              placeholder="댓글을 남겨보세요."
            ></textarea>

            <div class="community-detail-div-11">
              <button class="community-detail-button-05" type="submit">
                등록
              </button>
            </div>
          </div>
        </div>
      </form>

      <div id="reply-list-container" class="stack-gap-8">
        {{#replies}}
        <div class="fx-group-flex-gap4 reply-item">
        
          <div class="flex-fill">
            <div class="row-between-center-mb1">
              <div class="inline-items-gap-2">
                <span class="community-detail-span-05">{{username}}</span>
                <span class="community-detail-span-06">{{createdAtDisplay}}</span>
              </div>

              {{#isOwner}}
              <div class="inline-items-gap-2">
                <button class="link-inline-xs" type="button" onclick="showReplyEdit({{boardId}}, {{id}})">
                  <span class="icon-ms-sm">edit</span> 수정
                </button>

                <form action="/boards/{{boardId}}/replies/{{id}}/delete" method="post">
                  <button class="link-inline-xs" type="submit">
                    <span class="icon-ms-sm">delete</span> 삭제
                  </button>
                </form>
              </div>
              {{/isOwner}}
            </div>

            <p class="text-body-sm-relaxed" id="reply-content-{{id}}">
              {{content}}
            </p>

            <div id="reply-edit-box-{{id}}" hidden>
              <textarea
                id="reply-textarea-{{id}}"
                class="community-detail-textarea-01"
                rows="4"
                placeholder="댓글 내용을 수정하세요."
              >{{content}}</textarea>

              <div class="community-detail-div-11">
                <button class="community-detail-button-05" type="button" onclick="updateReply({{boardId}}, {{id}})">
                  저장
                </button>

                <button class="community-detail-button-03" type="button" onclick="cancelReplyEdit({{id}})">
                  취소
                </button>
              </div>
            </div>

          </div>
        </div>
        {{/replies}}

        <div class="community-detail-div-14">
          <button id="reply-more-btn" class="community-detail-button-06" type="button">
            댓글 더보기 <span class="icon-ms-base">expand_more</span>
          </button>
        </div>
      </div>
    </div>

    <div class="community-detail-div-15">
      <a class="community-detail-button-07" href="/boards">
        목록으로 돌아가기
      </a>
    </div>

    {{/board}}

  </main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
  <script>
    function showReplyEdit(boardId, replyId) {
      document.getElementById("reply-content-" + replyId).hidden = true;
      document.getElementById("reply-edit-box-" + replyId).hidden = false;
    }

    function cancelReplyEdit(replyId) {
      document.getElementById("reply-content-" + replyId).hidden = false;
      document.getElementById("reply-edit-box-" + replyId).hidden = true;
    }

    async function updateReply(boardId, replyId) {
      const textarea = document.getElementById("reply-textarea-" + replyId);
      const content = textarea.value.trim();

      if (!content) {
        alert("댓글 내용을 입력해주세요.");
        return;
      }

      try {
        const response = await fetch("/boards/" + boardId + "/replies/" + replyId + "/update", {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded"
          },
          body: new URLSearchParams({
            content: content
          })
        });

        if (!response.ok) {
          alert("댓글 수정에 실패했습니다.");
          return;
        }

        const data = await response.json();

        document.getElementById("reply-content-" + replyId).innerText = data.content;
        document.getElementById("reply-content-" + replyId).hidden = false;
        document.getElementById("reply-edit-box-" + replyId).hidden = true;
      } catch (e) {
        alert("서버 요청 중 오류가 발생했습니다.");
      }
    }

      // 4) JS 토글 함수 좋아요함수
  async function toggleBoardLike() {
  const btn = document.getElementById("board-like-btn");
  const boardId = btn.dataset.boardId;
  const countEl = document.getElementById("board-like-count");
  const iconEl = document.getElementById("board-like-icon");

  try {
    const response = await fetch("/boards/" + boardId + "/likes/toggle", { method: "POST" });

    if (!response.ok) {
      alert("자신의 글에는 좋아요를 누를 수 없습니다.");
      return;
    }

    const data = await response.json(); // { liked, likeCount }

    countEl.innerText = data.likeCount;

    if (data.liked) {
      btn.classList.add("is-liked");
      iconEl.innerText = "favorite";
    } else {
      btn.classList.remove("is-liked");
      iconEl.innerText = "favorite_border";
    }
  } catch (e) {
    alert("서버 요청 중 오류가 발생했습니다.");
  }
}

const likeBtn = document.getElementById("board-like-btn");
if (likeBtn) likeBtn.addEventListener("click", toggleBoardLike);

// 공유하기 버튼 프론트 web api
async function copyCurrentUrl() {
  const url = window.location.href;

  try {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(url);
    } else {
      const ta = document.createElement("textarea");
      ta.value = url;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      const ok = document.execCommand("copy");
      document.body.removeChild(ta);
      if (!ok) throw new Error("copy failed");
    }

    alert("주소가 복사되었습니다.");
  } catch (e) {
    alert("주소 복사에 실패했습니다.");
  }
}

document.addEventListener("DOMContentLoaded", function () {
  const shareBtn = document.getElementById("board-share-btn");
  if (shareBtn) {
    shareBtn.addEventListener("click", function (e) {
      e.preventDefault();
      copyCurrentUrl();
    });
  }
  initReplyPaging();
});

// 댓글 페이징
const replyPageSize = 3;
let replyVisibleCount = 3;

function renderReplyPage() {
  const items = Array.from(document.querySelectorAll(".reply-item"));
  items.forEach((el, idx) => {
    el.hidden = idx >= replyVisibleCount;
  });

  const moreBtn = document.getElementById("reply-more-btn");
  if (moreBtn) {
    moreBtn.hidden = replyVisibleCount >= items.length;
  }
}

function initReplyPaging() {
  const moreBtn = document.getElementById("reply-more-btn");
  if (moreBtn) {
    moreBtn.addEventListener("click", function () {
      replyVisibleCount += replyPageSize;
      renderReplyPage();
    });
  }
  renderReplyPage();
}

function escapeHtml(str) {
  return String(str)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function createReplyItemHtml(reply) {
  return `
    <div class="fx-group-flex-gap4 reply-item">
      <div class="flex-fill">
        <div class="row-between-center-mb1">
          <div class="inline-items-gap-2">
            <span class="community-detail-span-05">${escapeHtml(reply.username)}</span>
            <span class="community-detail-span-06">${escapeHtml(reply.createdAtDisplay)}</span>
          </div>
          <div class="inline-items-gap-2">
            <button class="link-inline-xs" type="button" onclick="showReplyEdit(${reply.boardId}, ${reply.id})">
              <span class="icon-ms-sm">edit</span> 수정
            </button>
            <form action="/boards/${reply.boardId}/replies/${reply.id}/delete" method="post">
              <button class="link-inline-xs" type="submit">
                <span class="icon-ms-sm">delete</span> 삭제
              </button>
            </form>
          </div>
        </div>

        <p class="text-body-sm-relaxed" id="reply-content-${reply.id}">
          ${escapeHtml(reply.content)}
        </p>

        <div id="reply-edit-box-${reply.id}" hidden>
          <textarea
            id="reply-textarea-${reply.id}"
            class="community-detail-textarea-01"
            rows="4"
            placeholder="댓글 내용을 수정하세요."
          >${escapeHtml(reply.content)}</textarea>

          <div class="community-detail-div-11">
            <button class="community-detail-button-05" type="button" onclick="updateReply(${reply.boardId}, ${reply.id})">
              저장
            </button>

            <button class="community-detail-button-03" type="button" onclick="cancelReplyEdit(${reply.id})">
              취소
            </button>
          </div>
        </div>
      </div>
    </div>
  `;
}

async function createReplyAjax(e) {
  e.preventDefault();

  const form = document.getElementById("reply-create-form");
  const textarea = document.getElementById("reply-create-content");
  const content = textarea.value.trim();

  if (!content) {
    alert("댓글 내용을 입력해주세요.");
    return;
  }

  const boardId = form.dataset.boardId;

  try {
    const response = await fetch("/boards/" + boardId + "/replies/ajax", {
      method: "POST",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded"
      },
      body: new URLSearchParams({ content: content })
    });

    if (!response.ok) {
      alert("댓글 등록에 실패했습니다.");
      return;
    }

    const data = await response.json();
    if (!data.success) {
      alert("댓글 등록에 실패했습니다.");
      return;
    }

    const list = document.getElementById("reply-list-container");
    const moreWrap = document.querySelector(".community-detail-div-14");
    const wrapper = document.createElement("div");
    wrapper.innerHTML = createReplyItemHtml(data);
    const newReplyEl = wrapper.firstElementChild;

    const firstReply = list.querySelector(".reply-item");
    if (firstReply) {
      list.insertBefore(newReplyEl, firstReply);
    } else if (moreWrap) {
      list.insertBefore(newReplyEl, moreWrap);
    } else {
      list.appendChild(newReplyEl);
    }

    textarea.value = "";

    const countEl = document.getElementById("reply-count-value");
    const nextCount = Number(countEl.textContent || "0") + 1;
    countEl.textContent = String(nextCount);

    replyVisibleCount += 1;
    renderReplyPage();
  } catch (e2) {
    alert("서버 요청 중 오류가 발생했습니다.");
  }
}

const replyCreateForm = document.getElementById("reply-create-form");
if (replyCreateForm) {
  replyCreateForm.addEventListener("submit", createReplyAjax);
}
  </script>

</body>
</html>
