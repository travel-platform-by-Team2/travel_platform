<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Community Post Detail</title>
  {{>partials/head-assets}}
</head>

<body class="page-body">
  {{>partials/header}}

  <div class="page-topbar">
    <div class="container-7xl-px6"></div>
  </div>

  <main class="page-main-wrap-5xl">

    <div class="mb-6">
      <a class="community-detail-button-01" href="/boards">
        <span class="icon-ms-lg">arrow_back</span>
        <span class="community-detail-span-01">목록으로</span>
      </a>
    </div>

    {{#board}}

    <div class="community-detail-div-01">

      <div class="community-detail-div-02">
        <div class="community-detail-div-03">

          <div class="row-between-center">
            <span class="community-detail-span-02">
              여행 계획
            </span>

            {{#isOwner}}
            <div class="calendar-add-event-div-06">
              <a class="community-detail-button-02" href="/boards/{{id}}/edit">수정</a>

              <form action="/boards/{{id}}/delete" method="post">
                <button class="community-detail-button-03" type="submit">
                  삭제
                </button>
              </form>
            </div>
            {{/isOwner}}
          </div>

          <div>
            <h1 class="community-detail-h1-01">
              {{title}}
            </h1>

            <div class="community-detail-div-04">
              <div class="community-create-div-03">
                <div class="inline-items-gap-2">
                  

                  <span class="community-detail-span-03">
                    {{username}}
                  </span>
                </div>

                <span>{{createdAt}}</span>
              </div>

              <div class="community-detail-div-06">
                <span class="icon-ms-lg">visibility</span>
                <span>{{viewCount}}</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="p-8">
        <div class="prose-reading-lg">
          <p class="mb-6">
            {{{content}}}
          </p>
        </div>

        <div class="community-detail-div-08">
          <button class="fx-group-chip-outline">
            <span class="icon-ms-hover-fill-current">favorite</span>
            <span class="fw-medium-500">좋아요 128</span>
          </button>

          <button class="community-detail-button-04">
            <span class="icon-ms-base">share</span>
            <span class="fw-medium-500">공유하기</span>
          </button>
        </div>
      </div>

    </div>

    <div class="community-detail-div-09">
      <h3 class="section-title-row">
        댓글 <span class="text-primary">{{replyCount}}</span>
      </h3>

      <form action="/boards/{{id}}/replies" method="post">
        <div class="community-detail-div-10">
          

          <div class="flex-fill">
            <textarea
              class="community-detail-textarea-01"
              name="content"
              placeholder="댓글을 남겨보세요."
            ></textarea>

            <div class="community-detail-div-11">
              <button class="community-detail-button-05" type="submit">
                등록
              </button>
            </div>
          </div>
        </div>
      </form>

      <div class="stack-gap-8">
        {{#replies}}
        <div class="fx-group-flex-gap4">
        
          <div class="flex-fill">
            <div class="row-between-center-mb1">
              <div class="inline-items-gap-2">
                <span class="community-detail-span-05">{{username}}</span>
                <span class="community-detail-span-06">{{createdAt}}</span>
              </div>

              {{#isOwner}}
              <div class="inline-items-gap-2">
                <button class="link-inline-xs" type="button" onclick="showReplyEdit({{boardId}}, {{id}})">
                  <span class="icon-ms-sm">edit</span> 수정
                </button>

                <form action="/boards/{{boardId}}/replies/{{id}}/delete" method="post">
                  <button class="link-inline-xs" type="submit">
                    <span class="icon-ms-sm">delete</span> 삭제
                  </button>
                </form>
              </div>
              {{/isOwner}}
            </div>

            <p class="text-body-sm-relaxed" id="reply-content-{{id}}">
              {{content}}
            </p>

            <div id="reply-edit-box-{{id}}" hidden>
              <textarea
                id="reply-textarea-{{id}}"
                class="community-detail-textarea-01"
                rows="4"
                placeholder="댓글 내용을 수정하세요."
              >{{content}}</textarea>

              <div class="community-detail-div-11">
                <button class="community-detail-button-05" type="button" onclick="updateReply({{boardId}}, {{id}})">
                  저장
                </button>

                <button class="community-detail-button-03" type="button" onclick="cancelReplyEdit({{id}})">
                  취소
                </button>
              </div>
            </div>

            <div class="community-detail-div-12">
              <button class="link-inline-xs" type="button">
                <span class="icon-ms-sm">thumb_up</span> 좋아요
              </button>
            </div>
          </div>
        </div>
        {{/replies}}

        <div class="community-detail-div-14">
          <button class="community-detail-button-06" type="button">
            댓글 더보기 <span class="icon-ms-base">expand_more</span>
          </button>
        </div>
      </div>
    </div>

    <div class="community-detail-div-15">
      <a class="community-detail-button-07" href="/boards">
        목록으로 돌아가기
      </a>
    </div>

    {{/board}}

  </main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}

  <script>
    function showReplyEdit(boardId, replyId) {
      document.getElementById("reply-content-" + replyId).hidden = true;
      document.getElementById("reply-edit-box-" + replyId).hidden = false;
    }

    function cancelReplyEdit(replyId) {
      document.getElementById("reply-content-" + replyId).hidden = false;
      document.getElementById("reply-edit-box-" + replyId).hidden = true;
    }

    async function updateReply(boardId, replyId) {
      const textarea = document.getElementById("reply-textarea-" + replyId);
      const content = textarea.value.trim();

      if (!content) {
        alert("댓글 내용을 입력해주세요.");
        return;
      }

      try {
        const response = await fetch("/boards/" + boardId + "/replies/" + replyId + "/update", {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded"
          },
          body: new URLSearchParams({
            content: content
          })
        });

        if (!response.ok) {
          alert("댓글 수정에 실패했습니다.");
          return;
        }

        const data = await response.json();

        document.getElementById("reply-content-" + replyId).innerText = data.content;
        document.getElementById("reply-content-" + replyId).hidden = false;
        document.getElementById("reply-edit-box-" + replyId).hidden = true;
      } catch (e) {
        alert("서버 요청 중 오류가 발생했습니다.");
      }
    }
  </script>

</body>
</html>