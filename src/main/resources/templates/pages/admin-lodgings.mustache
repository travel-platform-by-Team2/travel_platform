<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 숙소 관리</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{>partials/admin-sidebar}}

        <section class="admin-content">
          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">숙소 관리</h1>
              <p class="admin-page-subtitle">등록된 숙소 현황을 확인하고 관리하는 관리자 시안을 Bootstrap 기반 Mustache 화면으로 재구성했습니다.</p>
            </div>
          </div>

          <div class="admin-metric-grid">
            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div class="admin-metric-icon metric-icon-blue">
                  <span class="material-symbols-outlined">domain</span>
                </div>
              </div>
              <span class="admin-metric-label">전체 숙소</span>
              <p class="admin-metric-value">1,240</p>
            </article>

            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div class="admin-metric-icon metric-icon-emerald">
                  <span class="material-symbols-outlined">check_circle</span>
                </div>
              </div>
              <span class="admin-metric-label">운영 중인 숙소</span>
              <p class="admin-metric-value">1,185</p>
            </article>
          </div>

          <section class="admin-panel">
            <div class="admin-toolbar">
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <h2 class="admin-table-title mb-0">숙소 목록</h2>
                <span class="admin-pill status-neutral">Total 1,240</span>
              </div>

              <div class="admin-search-group">
                <select class="form-select admin-select-field">
                  <option>상태 전체</option>
                  <option>운영 중</option>
                  <option>점검 중</option>
                  <option>폐업</option>
                </select>
                <div class="admin-search-wrap">
                  <span class="material-symbols-outlined">search</span>
                  <input class="form-control admin-search-field" type="text" placeholder="숙소명 검색">
                </div>
              </div>
            </div>

            <div class="admin-table-wrap">
              <table class="table admin-table">
                <thead>
                  <tr>
                    <th>숙소명</th>
                    <th>지역</th>
                    <th>상태</th>
                    <th>등록일</th>
                    <th class="text-center">관리</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><p class="admin-name">그랜드 하얏트 서울</p></td>
                    <td>서울 용산구</td>
                    <td><span class="admin-status-badge status-success">운영 중</span></td>
                    <td>2023.10.15</td>
                    <td class="text-center">
                      <div class="admin-action-menu justify-content-center">
                        <button class="admin-icon-button" type="button" aria-label="숙소 액션">
                          <span class="material-symbols-outlined">more_vert</span>
                        </button>
                        <div class="admin-action-card text-start">
                          <p class="admin-action-card__label">상태 변경</p>
                          <a class="admin-action-link" href="#" onclick="return false;" aria-disabled="true">
                            <span class="material-symbols-outlined">radio_button_checked</span>
                            <span>운영중</span>
                          </a>
                          <a class="admin-action-link" href="#" onclick="return false;" aria-disabled="true">
                            <span class="material-symbols-outlined">radio_button_checked</span>
                            <span>점검중</span>
                          </a>
                          <a class="admin-action-link" href="#" onclick="return false;" aria-disabled="true">
                            <span class="material-symbols-outlined">radio_button_checked</span>
                            <span>폐업</span>
                          </a>
                          <a class="admin-action-link is-danger" href="#" onclick="return false;" aria-disabled="true">
                            <span class="material-symbols-outlined">delete</span>
                            <span>삭제</span>
                          </a>
                        </div>
                      </div>
                    </td>
                  </tr>
                  <tr>
                    <td><p class="admin-name">제주 신라 호텔</p></td>
                    <td>제주 서귀포시</td>
                    <td><span class="admin-status-badge status-success">운영 중</span></td>
                    <td>2023.09.28</td>
                    <td class="text-center">
                      <button class="admin-icon-button" type="button" aria-label="숙소 액션">
                        <span class="material-symbols-outlined">edit_square</span>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td><p class="admin-name">가평 푸른숲 펜션</p></td>
                    <td>경기 가평군</td>
                    <td><span class="admin-status-badge status-warning">점검 중</span></td>
                    <td>2023.11.02</td>
                    <td class="text-center">
                      <button class="admin-icon-button" type="button" aria-label="숙소 액션">
                        <span class="material-symbols-outlined">edit_square</span>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td><p class="admin-name">부산 해운대 엘시티</p></td>
                    <td>부산 해운대구</td>
                    <td><span class="admin-status-badge status-success">운영 중</span></td>
                    <td>2023.08.14</td>
                    <td class="text-center">
                      <button class="admin-icon-button" type="button" aria-label="숙소 액션">
                        <span class="material-symbols-outlined">edit_square</span>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td><p class="admin-name">강릉 바다풍경 스테이</p></td>
                    <td>강원 강릉시</td>
                    <td><span class="admin-status-badge status-danger">폐업</span></td>
                    <td>2023.05.21</td>
                    <td class="text-center">
                      <button class="admin-icon-button" type="button" aria-label="숙소 액션">
                        <span class="material-symbols-outlined">edit_square</span>
                      </button>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="admin-panel__footer">
              <p class="admin-pagination-note">Showing 1 to 5 of 1,240 results</p>
              <div class="admin-pagination">
                <button class="admin-page-button" type="button" disabled>
                  <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button class="admin-page-button is-active-page" type="button">1</button>
                <button class="admin-page-button" type="button">2</button>
                <button class="admin-page-button" type="button">3</button>
                <span class="text-muted">...</span>
                <button class="admin-page-button" type="button">248</button>
                <button class="admin-page-button" type="button">
                  <span class="material-symbols-outlined">chevron_right</span>
                </button>
              </div>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
