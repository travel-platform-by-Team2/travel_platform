<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Global Chatbot - Classic Messenger Variant 1</title>
  {{>partials/head-assets}}
</head>
<body class="page-body-relative-hidden-shell">
  {{>partials/header}}

<!-- Main Content Background (Simulated Page) -->
<div class="chatbot-demo-div-01" data-alt="Abstract dotted background pattern" style="background-image: radial-gradient(#306ee8 0.5px, transparent 0.5px); background-size: 24px 24px;">
</div>
<!-- Layout Container -->
<div class="layout-container-stack-rel">
<!-- Navbar Placeholder (To give context) -->
<!-- Main Content Area Placeholder -->
<main class="chatbot-demo-main-01">
<div class="chatbot-demo-div-02">
<h1 class="chatbot-demo-h1-01">Discover South Korea</h1>
<p class="chatbot-demo-p-01">Plan your perfect trip with our AI assistant.</p>
<div class="chatbot-demo-div-03" data-alt="Hero image placeholder for travel destination">
<span class="icon-ms-6xl">image</span>
</div>
</div>
</main>
<!-- Chat Widget Container (Bottom Right) -->
<div class="chatbot-demo-div-04">
<!-- Chat Window -->
<div class="chatbot-demo-div-05">
<!-- Chat Header -->
<div class="chatbot-demo-div-06">
<div class="chatbot-demo-div-07">
<div class="is-relative">
<div class="chatbot-fab-icon-shell">
<span class="icon-ms-24-white">smart_toy</span>
</div>
<div class="chatbot-demo-div-08"></div>
</div>
<div class="chatbot-demo-div-09">
<h2 class="chatbot-demo-h2-01">여행 챗봇</h2>
<p class="chatbot-demo-p-02">여행 관련 질문을 입력하세요</p>
</div>
</div>
<div class="chatbot-demo-div-10">
<button class="btn-icon-overlay">
<span class="icon-ms-20">remove</span>
</button>
<button class="btn-icon-overlay">
<span class="icon-ms-20">close</span>
</button>
</div>
</div>
<!-- Chat Area -->
<div class="chatbot-scroll-body">
<!-- Date Separator -->
<div class="chatbot-demo-div-11">
<span class="chatbot-demo-span-01">Today</span>
</div>
<!-- Bot Message -->
<div class="chatbot-demo-div-12">
<div class="icon-circle-primary-sm">
<span class="icon-ms-18-primary">smart_toy</span>
</div>
<div class="chatbot-demo-div-13">
<span class="chatbot-demo-span-02">AI Assistant</span>
<div class="chatbot-demo-div-14">
                                안녕하세요! 👋<br/>여행 일정, 숙소 추천, 준비물까지 도와드릴게요.
                            </div>
</div>
</div>
<!-- User Message -->
<div class="chatbot-demo-div-15">
<div class="chatbot-demo-div-16">
<div class="chatbot-demo-div-17">
                                제주도 2박 3일 여행 코스 추천해줘.
                            </div>
<span class="chatbot-demo-span-03">Read 10:42 AM</span>
</div>
</div>
<!-- Bot Typing Indicator -->
<div class="chatbot-demo-div-12">
<div class="icon-circle-primary-sm">
<span class="icon-ms-18-primary">smart_toy</span>
</div>
<div class="chatbot-demo-div-18">
<div class="typing-dot" style="animation-delay: 0ms"></div>
<div class="typing-dot" style="animation-delay: 150ms"></div>
<div class="typing-dot" style="animation-delay: 300ms"></div>
</div>
</div>
<!-- Quick Action Chips -->
<div class="chatbot-demo-div-19">
<button class="chip-suggest">
                            2박 3일 코스 추천
                        </button>
<button class="chip-suggest">
                            비 오는 날 추천 코스 ☔
                        </button>
<button class="chip-suggest">
                            맛집 추천 🍜
                        </button>
</div>
</div>
<!-- Input Area -->
<div class="chatbot-demo-div-20">
<div class="chatbot-demo-div-21">
<input class="chatbot-demo-input-01" placeholder="메시지를 입력하세요..." type="text"/>
<button class="fx-group-fab-sm">
<span class="icon-ms-18-hover-right">send</span>
</button>
</div>
<div class="chatbot-demo-div-22">
<p class="chatbot-demo-p-03">Powered by TravelAI</p>
</div>
</div>
</div>
<!-- Floating Action Button (FAB) -->
<button class="fx-group-fab-lg">
<span class="icon-ms-28">chat_bubble</span>
<span class="chatbot-demo-span-04"></span>
</button>
</div>
</div>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
