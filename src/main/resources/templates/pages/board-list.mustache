<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TripKorea - 커뮤니티</title>
  {{>partials/head-assets}}
  {{>partials/chatbot-assets}}
</head>
<body class="community-list-body-01">
  {{>partials/header}}

<main class="page-main-wrap-1440">
<div class="layout-stack-960">
<div class="community-list-div-01">
<div class="stack-gap-2">
<h1 class="community-list-h1-01">커뮤니티</h1>
<p class="community-list-p-01">
                        여행자들과 함께 소통하며 대한민국 곳곳의 여행 팁과 숨은 명소를 발견해 보세요.
                    </p>
</div>
<a class="community-list-button-01" href="/boards/new">
<span class="icon-ms-20">edit</span>
<span>글쓰기</span>
</a>
</div>

<div class="community-list-div-02 community-board-hero">
  <div class="community-board-hero__backdrop"></div>

  <div class="community-board-hero__tab-row">
    <div class="community-board-hero__tabs chips-scroll-mask">
      <a class="community-filter-btn cat-all {{^page.category}}is-active{{/page.category}}" href="/boards{{#page.sort}}?sort={{page.sort}}{{/page.sort}}{{#page.keyword}}{{#page.sort}}&{{/page.sort}}keyword={{page.keyword}}{{/page.keyword}}">
        전체
      </a>

      <a class="community-filter-btn cat-tips {{#page.isTips}}is-active{{/page.isTips}}" href="/boards?category=tips{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
        여행 팁
      </a>

      <a class="community-filter-btn cat-plan {{#page.isPlan}}is-active{{/page.isPlan}}" href="/boards?category=plan{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
        여행 계획
      </a>

      <a class="community-filter-btn cat-food {{#page.isFood}}is-active{{/page.isFood}}" href="/boards?category=food{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
        맛집/카페
      </a>

      <a class="community-filter-btn cat-review {{#page.isReview}}is-active{{/page.isReview}}" href="/boards?category=review{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
        숙소 후기
      </a>

      <a class="community-filter-btn cat-qna {{#page.isQna}}is-active{{/page.isQna}}" href="/boards?category=qna{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
        질문/답변
      </a>
    </div>
  </div>

  <div class="community-board-hero__controls">
    <form action="/boards" method="get" class="community-board-search">
      {{#page.category}}<input type="hidden" name="category" value="{{page.category}}">{{/page.category}}
      {{#page.sort}}<input type="hidden" name="sort" value="{{page.sort}}">{{/page.sort}}
      <div class="community-board-search__field">
        <span class="icon-ms-18 community-board-search__icon">search</span>
        <input
          type="text"
          name="keyword"
          value="{{page.keyword}}"
          class="community-board-search__input"
          placeholder="제목 또는 내용 검색">
      </div>
      <button class="community-board-search__submit" type="submit">
        검색
      </button>
    </form>

    <div class="community-board-sort-group">
      <a class="community-board-reset" href="/boards">
        <span class="icon-ms-18">restart_alt</span>
        필터 초기화
      </a>

      <div class="community-sort-wrap">
        <details class="community-sort-dropdown">
          <summary class="community-sort-summary community-board-sort-summary">
            <span>{{page.sortLabel}}</span>
            <span class="icon-ms-18">expand_more</span>
          </summary>

          <div class="community-sort-menu community-board-sort-menu" aria-label="게시글 정렬">
            <a class="community-sort-option {{#page.isSortLatest}}is-active{{/page.isSortLatest}}"
            href="/boards?sort=latest{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">날짜순 ↑</a>

            <a class="community-sort-option {{#page.isSortDate}}is-active{{/page.isSortDate}}"
            href="/boards?sort=date{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">날짜순 ↓</a>

            <a class="community-sort-option {{#page.isSortViews}}is-active{{/page.isSortViews}}"
            href="/boards?sort=view{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">조회순 ↑</a>

            <a class="community-sort-option {{#page.isSortDownviews}}is-active{{/page.isSortDownviews}}"
            href="/boards?sort=downview{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">조회순 ↓</a>

            <a class="community-sort-option {{#page.isSortLikes}}is-active{{/page.isSortLikes}}"
            href="/boards?sort=likes{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">좋아요순 ↑</a>

            <a class="community-sort-option {{#page.isSortDownlikes}}is-active{{/page.isSortDownlikes}}"
            href="/boards?sort=downlikes{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">좋아요 ↓</a>
          </div>
        </details>
      </div>
    </div>
  </div>
</div>

<div class="stack-gap-3">
{{#page.boards}}
<a class="place-card-row" href="/boards/{{id}}">
<div class="community-list-div-04">
<div class="inline-row-gap2-mb2">
<span class="community-list-span-01 {{categoryClass}}">
                                {{categoryLabel}}
                             </span>
<span class="community-list-span-02">• {{createdAtDisplay}}</span>
</div>
<h3 class="place-card-title">
                            {{title}}
                        </h3>
<p class="text-muted-sm-truncate">
                            {{summary}}
                        </p>
</div>
<div class="place-card-meta">
<div class="inline-row-gap1-5">
<span class="icon-ms-18">favorite</span>
<span>{{likeCount}}</span>
</div>
<div class="inline-row-gap1-5">
<span class="icon-ms-18">visibility</span>
<span>{{viewCount}}</span>
</div>
<div class="community-list-div-05">
<span class="icon-ms-18">chat_bubble</span>
<span>{{replyCount}}</span>
</div>
<div class="inline-row-gap2-ml2">
<span class="text-main-xs-medium">{{username}}</span>
</div>
</div>
</a>
{{/page.boards}}
{{^page.boards}}
<p class="text-muted-sm-truncate">아직 게시글이 없습니다.</p>
{{/page.boards}}

<div class="pagination-wrap">
  {{#page.prevPage}}
  <a class="community-page-btn" href="/boards?page={{page.prevPage}}{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
    이전
  </a>
  {{/page.prevPage}}

  {{#page.pageItems}}
    {{#current}}
    <span class="community-page-btn is-active">{{displayNumber}}</span>
    {{/current}}

    {{^current}}
    <a class="community-page-btn" href="/boards?page={{page}}{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
      {{displayNumber}}
    </a>
    {{/current}}
  {{/page.pageItems}}

  {{#page.nextPage}}
  <a class="community-page-btn" href="/boards?page={{page.nextPage}}{{#page.category}}&category={{page.category}}{{/page.category}}{{#page.sort}}&sort={{page.sort}}{{/page.sort}}{{#page.keyword}}&keyword={{page.keyword}}{{/page.keyword}}">
    다음
  </a>
  {{/page.nextPage}}
</div>
</div>
</main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
