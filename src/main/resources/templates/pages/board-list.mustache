<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TripKorea - 커뮤니티</title>
  {{>partials/head-assets}}
</head>
<body class="community-list-body-01">
  {{>partials/header}}

<main class="page-main-wrap-1440">
<div class="layout-stack-960">
<div class="community-list-div-01">
<div class="stack-gap-2">
<h1 class="community-list-h1-01">커뮤니티</h1>
<p class="community-list-p-01">
                        여행자들과 함께 소통하며 대한민국 곳곳의 여행 팁과 숨은 명소를 발견해 보세요.
                    </p>
</div>
<a class="community-list-button-01" href="/boards/new">
<span class="icon-ms-20">edit</span>
<span>글쓰기</span>
</a>
</div>
<div class="community-list-div-02">
  <div class="community-list-div-03">
    <div class="chips-scroll-mask"> 
      <a class="community-filter-btn cat-all {{^model.category}}is-active{{/model.category}}" href="/boards">
        전체
      </a>

      <a class="community-filter-btn cat-tips {{#model.isTips}}is-active{{/model.isTips}}" href="/boards?category=tips">
        여행 팁
      </a>

      <a class="community-filter-btn cat-plan {{#model.isPlan}}is-active{{/model.isPlan}}" href="/boards?category=plan">
        여행 계획
      </a>

      <a class="community-filter-btn cat-food {{#model.isFood}}is-active{{/model.isFood}}" href="/boards?category=food">
        맛집/카페
      </a>

      <a class="community-filter-btn cat-review {{#model.isReview}}is-active{{/model.isReview}}" href="/boards?category=review">
        숙소 후기
      </a>

      <a class="community-filter-btn cat-qna {{#model.isQna}}is-active{{/model.isQna}}" href="/boards?category=qna">
        질문/답변
      </a>
    </div>

    <a class="community-list-button-03" href="/boards">
      <span class="icon-ms-18">restart_alt</span>
      필터 초기화
    </a>
  </div>
</div>
<div class="stack-gap-3">
{{#model.boards}}
<a class="place-card-row" href="/boards/{{id}}">
<div class="community-list-div-04">
<div class="inline-row-gap2-mb2">
<span class="community-list-span-01 {{categoryClass}}">
                                {{categoryLabel}}
                             </span>
<span class="community-list-span-02">• {{createdAtDisplay}}</span>
</div>
<h3 class="place-card-title">
                            {{title}}
                        </h3>
<p class="text-muted-sm-truncate">
                            {{summary}}
                        </p>
</div>
<div class="place-card-meta">
<div class="inline-row-gap1-5">
<span class="icon-ms-18">visibility</span>
<span>{{viewCount}}</span>
</div>
<div class="community-list-div-05">
<span class="icon-ms-18">chat_bubble</span>
<span>{{replyCount}}</span>
</div>
<div class="inline-row-gap2-ml2">
<span class="text-main-xs-medium">{{username}}</span>
</div>
</div>
</a>
{{/model.boards}}
{{^model.boards}}
<p class="text-muted-sm-truncate">아직 게시글이 없습니다.</p>
{{/model.boards}}

<div class="pagination-wrap">
  {{#model.prevPage}}
  <a class="community-page-btn" href="/boards?page={{model.prevPage}}{{#model.category}}&category={{model.category}}{{/model.category}}">
    이전
  </a>
  {{/model.prevPage}}

  {{#model.pageItems}}
    {{#current}}
    <span class="community-page-btn is-active">{{displayNumber}}</span>
    {{/current}}

    {{^current}}
    <a class="community-page-btn" href="/boards?page={{page}}{{#model.category}}&category={{model.category}}{{/model.category}}">
      {{displayNumber}}
    </a>
    {{/current}}
  {{/model.pageItems}}

  {{#model.nextPage}}
  <a class="community-page-btn" href="/boards?page={{model.nextPage}}{{#model.category}}&category={{model.category}}{{/model.category}}">
    다음
  </a>
  {{/model.nextPage}}
</div>
</main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
