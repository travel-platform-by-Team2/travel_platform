<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelMate 관리자 - 사용자 관리</title>
  {{>partials/head-assets}}
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="page-body page-body-sans page-admin">
  {{>partials/header}}

  <main class="app-main admin-main">
    <div class="container-xxl">
      <div class="admin-page-shell">
        {{>partials/admin-sidebar}}

        <section class="admin-content">
          <div class="admin-page-header">
            <div>
              <h1 class="admin-page-title">사용자 관리</h1>
              <p class="admin-page-subtitle">등록된 사용자 목록을 조회하고 상태를 관리하는 관리자 화면입니다.</p>
            </div>
          </div>

          <div class="admin-metric-grid">
            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div class="admin-metric-icon metric-icon-blue">
                  <span class="material-symbols-outlined">groups</span>
                </div>
              </div>
              <span class="admin-metric-label">전체 사용자 수</span>
              <p class="admin-metric-value">{{totalUserCount}}</p>
            </article>

            <article class="admin-metric-card">
              <div class="admin-metric-card__top">
                <div class="admin-metric-icon metric-icon-rose">
                  <span class="material-symbols-outlined">block</span>
                </div>
              </div>
              <span class="admin-metric-label">비활성 사용자 수</span>
              <p class="admin-metric-value">{{inactiveUserCount}}</p>
            </article>
          </div>

          <section class="admin-panel">
            <div class="admin-toolbar">
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <h2 class="admin-table-title mb-0">사용자 목록</h2>
                <span class="admin-pill status-neutral">Total {{totalUserCount}}</span>
                <div class="admin-tab-shell" aria-label="사용자 상태 탭">
                  <a class="admin-tab-button{{#isAllTab}} is-active-tab{{/isAllTab}}" href="{{allTabHref}}">전체</a>
                  <a class="admin-tab-button{{#isActiveTab}} is-active-tab{{/isActiveTab}}" href="{{activeTabHref}}">활성</a>
                  <a class="admin-tab-button{{#isInactiveTab}} is-active-tab{{/isInactiveTab}}" href="{{inactiveTabHref}}">비활성</a>
                </div>
              </div>

              <div class="admin-search-group">
                <form class="admin-search-wrap" action="/admin/users" method="get">
                  {{#currentActive}}
                  <input type="hidden" name="active" value="true">
                  {{/currentActive}}
                  {{^isAllTab}}
                  {{^currentActive}}
                  <input type="hidden" name="active" value="false">
                  {{/currentActive}}
                  {{/isAllTab}}
                  <span class="material-symbols-outlined">search</span>
                  <input
                    class="form-control admin-search-field"
                    type="text"
                    name="keyword"
                    value="{{keyword}}"
                    placeholder="이름 또는 이메일 검색"
                  >
                  <button type="submit" class="admin-search-submit">검색</button>
                </form>
                </div>
            </div>

            <div class="admin-table-wrap">
              <table class="table admin-table">
                <thead>
                  <tr>
                    <th>사용자 정보</th>
                    <th>가입일</th>
                    <th>상태</th>
                    <th class="text-end">관리</th>
                  </tr>
                </thead>
                <tbody>
                  {{#hasUsers}}
                  {{#users}}
                  <tr>
                    <td>
                      <div class="d-flex flex-column gap-1">
                        <p class="admin-name mb-0">{{username}}</p>
                        <span class="text-muted">{{email}}</span>
                      </div>
                    </td>
                    <td>{{createdAt}}</td>
                    <td>
                      {{#active}}
                      <span class="admin-status-badge status-active">{{statusText}}</span>
                      {{/active}}
                      {{^active}}
                      <span class="admin-status-badge status-danger">{{statusText}}</span>
                      {{/active}}
                    </td>
                    <td class="text-end">
                      <form action="/admin/users/{{userId}}/status" method="post">
                        {{#currentActive}}
                        <input type="hidden" name="active" value="true">
                        {{/currentActive}}
                        {{^isAllTab}}
                        {{^currentActive}}
                        <input type="hidden" name="active" value="false">
                        {{/currentActive}}
                        {{/isAllTab}}
                        <input type="hidden" name="keyword" value="{{keyword}}">
                        <button class="admin-pill status-neutral" type="submit">{{managementLabel}}</button>
                      </form>
                    </td>
                  </tr>
                  {{/users}}
                  {{/hasUsers}}
                  {{^hasUsers}}
                  <tr>
                    <td colspan="4" class="text-center text-muted py-5">
                      조회된 사용자 데이터가 없습니다.
                    </td>
                  </tr>
                  {{/hasUsers}}
                </tbody>
              </table>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  {{>partials/footer}}
  {{>partials/scripts}}
  {{>partials/admin-page-scripts}}
</body>
</html>
