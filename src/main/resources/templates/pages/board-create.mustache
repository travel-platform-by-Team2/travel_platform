<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TravelKorea - Community Post Creation</title>
  {{>partials/head-assets}}
</head>
<body class="page-body-smooth">
  {{>partials/header}}

<main class="page-main-compact">
<div class="surface-panel">
<form action="/boards" method="post">
<div class="community-create-div-04">
<div class="stack-gap-2">
<label class="label-strong" for="category">
                        태그 (카테고리) <span class="text-danger">*</span>
</label>
<div class="is-relative">
<select class="select-control" id="category" name="category">
<option disabled="" selected="" value="">카테고리를 선택하세요</option>
<option value="tips">여행 팁</option>
<option value="plan">여행 계획</option>
<option value="food">맛집/카페</option>
<option value="review">숙소 후기</option>
<option value="qna">질문/답변</option>
</select>
<div class="input-icon-right">
<span class="icon-ms-base">expand_more</span>
</div>
</div>
</div>
<div class="stack-gap-2">
<label class="label-strong" for="title">
                        제목 <span class="text-danger">*</span>
</label>
<input class="input-control-solid" id="title" name="title" placeholder="제목을 입력하세요" type="text" value="{{title}}"/> <!-- 검증 실패 후에도 사용자가 입력한 제목을 유지 -->
{{#titleError}} <!-- 컨트롤러가 titleError를 모델에 넣은 경우에만 아래 문구를 표시 -->
<p class="text-danger text-caption">{{titleError}}</p> <!-- 제목 미입력 등 title 필드 검증 에러 메시지 출력 -->
{{/titleError}} <!-- 제목 에러 표시 블록 종료 -->
</div>
<div class="stack-gap-2">
<label class="label-strong" for="content">
                        내용 <span class="text-danger">*</span>
</label>
<textarea class="community-content-textarea" id="content" name="content" placeholder="여행 후기나 정보를 자유롭게 작성해주세요..." rows="16">{{content}}</textarea> <!-- 검증 실패 후에도 사용자가 입력한 본문을 유지 -->
{{#contentError}} <!-- 컨트롤러가 contentError를 모델에 넣은 경우에만 아래 문구를 표시 -->
<p class="text-danger text-caption">{{contentError}}</p> <!-- 내용 미입력 등 content 필드 검증 에러 메시지 출력 -->
{{/contentError}} <!-- 내용 에러 표시 블록 종료 -->
</div>
</div>
<div class="panel-footer-actions">
<a class="community-create-button-01" href="/boards">
                    취소
                </a>
<button class="community-create-button-02" type="submit">
                    작성 완료
                </button>
</div>
</div>
</form>
</main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
