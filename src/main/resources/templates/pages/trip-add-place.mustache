<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{#page}}{{detail.formattedTitle}}{{/page}}{{^page}}여행 장소 추가{{/page}}</title>
  {{>partials/head-assets}}
</head>
<body class="page-body-screen-sans-hidden">
  {{>partials/header}}

{{#page}}
<div id="tripPlacePage"
     data-plan-id="{{detail.id}}"
     data-existing-count="{{existingCount}}"
     data-save-url="{{saveUrl}}"
     data-detail-url="{{detailUrl}}">
  <div class="trip-plan-add-place-div-01">
    <div class="community-create-div-03">
      <h2 class="trip-plan-add-place-h2-01">{{detail.formattedTitle}}</h2>
      <div class="trip-plan-add-place-div-02"></div>
      <div class="trip-plan-add-place-div-03">
        <span class="icon-ms-base">calendar_month</span>
        <span>{{detail.travelPeriodLabel}}</span>
      </div>
    </div>
    <div class="chatbot-demo-div-07">
      <button class="trip-plan-add-place-button-01" id="cancelPlaceSelection" type="button">
        취소
      </button>
      <button class="trip-plan-add-place-button-02" id="saveSelectedPlaces" type="button">
        <span class="icon-ms-18">check</span>
        완료
      </button>
    </div>
  </div>

  <main class="trip-plan-add-place-main-01">
    <div class="trip-plan-add-place-div-04">
      <div class="trip-plan-add-place-div-05">
        <div class="is-relative">
          <span class="trip-plan-add-place-span-01">
            <span class="icon-ms-base">search</span>
          </span>
          <input id="placeSearchInput" class="trip-plan-add-place-input-01" placeholder="장소 검색 (예: 협재 해수욕장, 흑돼지 맛집)" type="text"/>
        </div>
      </div>

      <div class="trip-plan-add-place-div-06">
        <div class="strip-scroll-gap6" id="categoryTabs">
          <button class="trip-plan-add-place-button-03 active" data-category="" type="button">추천</button>
          <button class="tab-link-muted" data-category="AT4" type="button">명소</button>
          <button class="tab-link-muted" data-category="AD5" type="button">숙소</button>
        </div>
      </div>

      <div class="trip-plan-add-place-div-07" id="placeListContainer">
        <div class="empty-state">지도를 움직이거나 검색해서 장소를 골라보세요.</div>
      </div>

      <div class="trip-plan-add-place-div-08">
        <div class="trip-plan-add-place-div-09">
          <h4 class="trip-plan-add-place-h4-01">
            담을 장소 <span class="text-primary" id="selectedPlaceCount">0</span>
          </h4>
          <button class="trip-plan-add-place-button-04" id="clearSelectedPlaces" type="button">전체 삭제</button>
        </div>

        <div class="strip-scroll-gap3" id="selectedPlaceList">
          <div class="empty-state">아직 담은 장소가 없습니다.</div>
        </div>
      </div>

      {{#detail.hasPlaces}}
      <div class="community-list-div-02">
        <div class="row-between-center-mb2">
          <h4 class="trip-plan-add-place-h4-01">현재 저장된 장소</h4>
          <span class="text-primary">{{existingCount}}개</span>
        </div>
        {{#detail.places}}
        <div class="timeline-card">
          <div class="row-between-center">
            <strong>DAY {{dayOrder}}</strong>
            <span class="trip-plan-detail-span-04">{{placeName}}</span>
          </div>
          <p class="trip-plan-detail-p-01">{{address}}</p>
        </div>
        {{/detail.places}}
      </div>
      {{/detail.hasPlaces}}
    </div>

    <div class="trip-plan-add-place-div-13">
      <div class="trip-plan-add-place-div-14" style="position: relative;">
        <div id="tripMap" style="width:100%;height:100%;"></div>
        <div class="trip-plan-add-place-div-15" style="z-index: 2;">
          <button class="trip-plan-add-place-button-06" id="btnMyLocation" type="button">
            <span class="icon-ms-xl">my_location</span>
          </button>
          <div class="trip-plan-add-place-div-16">
            <button class="trip-plan-add-place-button-07" id="btnZoomIn" type="button">
              <span class="icon-ms-xl">add</span>
            </button>
            <button class="trip-plan-add-place-button-08" id="btnZoomOut" type="button">
              <span class="icon-ms-xl">remove</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
{{/page}}

  {{>partials/footer}}
  {{#page.kakaoMapAppKey}}
  <script src="https://dapi.kakao.com/v2/maps/sdk.js?appkey={{page.kakaoMapAppKey}}&libraries=services&autoload=false"></script>
  {{/page.kakaoMapAppKey}}
  <script src="/js/trip-add-place.js"></script>
  {{>partials/scripts}}
</body>
</html>
