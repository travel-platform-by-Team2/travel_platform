<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Add Place to Itinerary - TravelLog</title>
  {{>partials/head-assets}}
</head>
<body class="page-body-screen-sans-hidden">
  {{>partials/header}}

<div class="trip-plan-add-place-div-01">
<div class="community-create-div-03">
<h2 class="trip-plan-add-place-h2-01">{{#plan}}{{plan.title}}{{/plan}}{{^plan}}제주도 3박 4일 여행{{/plan}}</h2>
<div class="trip-plan-add-place-div-02"></div>
<div class="trip-plan-add-place-div-03">
<span class="icon-ms-base">calendar_month</span>
<span>1일차 - 10.15 (일)</span>
</div>
</div>
<div class="chatbot-demo-div-07">
<button class="trip-plan-add-place-button-01" type="button" onclick="location.href='/trip/detail'">
            취소
        </button>
<button class="trip-plan-add-place-button-02" type="button" onclick="location.href='/trip/detail'">
<span class="icon-ms-18">check</span>
            완료
        </button>
</div>
</div>
<main class="trip-plan-add-place-main-01">
<div class="trip-plan-add-place-div-04">
<div class="trip-plan-add-place-div-05">
<div class="is-relative">
<span class="trip-plan-add-place-span-01">
<span class="icon-ms-base">search</span>
</span>
<input id="placeSearchInput" class="trip-plan-add-place-input-01" placeholder="장소 검색 (예: 협재 해수욕장, 흑돼지 맛집)" type="text"/>
</div>
</div>
<div class="trip-plan-add-place-div-06">
<div class="strip-scroll-gap6" id="categoryTabs">
<button class="trip-plan-add-place-button-03 active" data-category="">추천</button>
<button class="tab-link-muted" data-category="AT4">명소</button>
<button class="tab-link-muted" data-category="AD5">숙소</button>
</div>
</div>
<div class="trip-plan-add-place-div-07" id="placeListContainer">
<!-- 장소 리스트 동적 렌더링 -->
</div>
<div class="trip-plan-add-place-div-08">
<div class="trip-plan-add-place-div-09">
<h4 class="trip-plan-add-place-h4-01">
                     담은 장소 <span class="text-primary">2</span>
</h4>
<button class="trip-plan-add-place-button-04">전체 삭제</button>
</div>
<div class="strip-scroll-gap3">
<div class="fx-group-thumb14">
<div class="trip-plan-add-place-div-10">
<img alt="Selected" class="trip-plan-add-place-img-01" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDN0kqyZcFwdNEc-a6CCMDKpnpzxbfAUmAPFkAX3RwNlNcepNzVGzu0LVVOJqUyOIdJjo_eqOl9wMEd9LP5VSNREoO0Lef-esqF_C4P1l2xhs2XTLnsXlXc0ZSRpU2CYjyFHxQlNI7wOE5w8C95e7U8g91UWwemD07rPGmwD2nZltMUw3z2kfSZRMdnMTxzPxCmLpPf9a17cMoP4KKqZOaOuQOrnx0cpP_nqWwIQw9GKkKEH1GiccYRRDnWFSMFaASs-ixCCJuNu10"/>
<div class="trip-plan-add-place-div-11">1</div>
</div>
<button class="trip-plan-add-place-button-05">
<span class="icon-ms-10">close</span>
</button>
<p class="trip-plan-add-place-p-01">협재 해수욕장</p>
</div>
<div class="fx-group-thumb14">
<div class="trip-plan-add-place-div-10">
<img alt="Selected" class="trip-plan-add-place-img-01" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB4ZheqmQogrR8X2-TKdy7R2gqxXEdqGUc9nE2nyWSvokMy9r-n2ev_5V4Qtfbvt3uvfw5M37yadCMfc3GdSlL6yS0aVReS7ul0-_r_mSPPLrWx-ykBrD6lM-jZSuCm3iI9u9ZgjwBmSyN5LjNQwIVwvOYDz7ihdQXhCUp86NU5NUxcdQzH7T0RWWF5k-5Lfs4AILaSfXiNiHiCF7dLyQFAhcbSh1IaXN23mX8_DgNse_PlFHdqYhpU57nuj-g1XAOSJ-MRvZldGqE"/>
<div class="trip-plan-add-place-div-11">2</div>
</div>
<button class="trip-plan-add-place-button-05">
<span class="icon-ms-10">close</span>
</button>
<p class="trip-plan-add-place-p-01">금능 샌드</p>
</div>
<div class="trip-plan-add-place-div-12">
<span class="icon-ms-lg">add</span>
</div>
</div>
</div>
</div>
<div class="trip-plan-add-place-div-13">
<div class="trip-plan-add-place-div-14" style="position: relative;">
<div id="tripMap" style="width:100%;height:100%;"></div>
<div class="trip-plan-add-place-div-15" style="z-index: 2;">
<button class="trip-plan-add-place-button-06" id="btnMyLocation">
<span class="icon-ms-xl">my_location</span>
</button>
<div class="trip-plan-add-place-div-16">
<button class="trip-plan-add-place-button-07" id="btnZoomIn">
<span class="icon-ms-xl">add</span>
</button>
<button class="trip-plan-add-place-button-08" id="btnZoomOut">
<span class="icon-ms-xl">remove</span>
</button>
</div>
</div>
</div>
</div>
</main>

  {{>partials/footer}}
  {{#kakaoMapAppKey}}
  <script src="https://dapi.kakao.com/v2/maps/sdk.js?appkey={{kakaoMapAppKey}}&libraries=services&autoload=false"></script>
  {{/kakaoMapAppKey}}
  <script src="/js/trip-add-place.js"></script>
  {{>partials/scripts}}
</body>
</html>
