<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Unified Map Exploration Variant 1</title>
  {{>partials/head-assets}}
  <style>
    .map-detail-main-01 { display: flex; flex: 1 1 auto; min-height: 0; }
    .map-detail-div-10 { position: relative; height: 100%; min-height: 0; flex: 1 1 auto; }
    .map-detail-div-11 { position: relative; height: 100%; min-height: 0; background: transparent !important; }
    #kakaoMap { width: 100%; height: 100%; min-height: 0; opacity: 1 !important; background: transparent !important; }
    .map-detail-search-card {
      width: 100%;
      max-width: 100%;
      background: #f3f4f6;
      border: 1px solid #dfe5ee;
      border-radius: 1rem;
      padding: 1rem;
    }
    .map-detail-search-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .map-detail-search-grid-top {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) repeat(2, minmax(0, 1fr));
      gap: 0.875rem;
      align-items: end;
    }
    .map-detail-search-grid-bottom {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(10.5rem, 1.05fr);
      gap: 0.875rem;
      align-items: end;
    }
    .map-detail-search-field {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-width: 0;
    }
    .map-detail-search-action {
      display: flex;
      align-items: flex-end;
      min-width: 0;
    }
    .map-detail-search-label {
      color: #64748b;
      font-size: 0.75rem;
      font-weight: 700;
      line-height: 1rem;
    }
    .map-detail-search-control {
      position: relative;
      display: flex;
      align-items: center;
    }
    .map-detail-search-select,
    .map-detail-search-input {
      width: 100%;
      min-height: 2.75rem;
      border: 1px solid #e2e8f0;
      border-radius: 0.75rem;
      background: #fff;
      color: #0f172a;
      font-size: 0.95rem;
      font-weight: 500;
      padding: 0.75rem 2.5rem 0.75rem 2.4rem;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }
    .map-detail-search-select {
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
    }
    .map-detail-search-select:focus,
    .map-detail-search-input:focus {
      outline: none;
      border-color: #1152d4;
      box-shadow: 0 0 0 3px rgba(17, 82, 212, 0.12);
    }
    .map-detail-search-icon-left,
    .map-detail-search-icon-right {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      pointer-events: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .map-detail-search-icon-left {
      left: 0.75rem;
    }
    .map-detail-search-icon-right {
      right: 0.75rem;
    }
    .map-detail-search-submit {
      min-width: 10.5rem;
      width: 100%;
      height: 2.75rem;
      border: 0;
      border-radius: 0.75rem;
    }
    @media (min-width: 1200px) {
      .map-detail-search-form {
        display: grid;
        /* Prevent date inputs from becoming too narrow and truncating YYYY-MM-DD. */
        grid-template-columns:
          minmax(0, 1.45fr)
          minmax(12.25rem, 1fr)
          minmax(12.25rem, 1fr)
          minmax(9.25rem, 1fr)
          minmax(11rem, 0.95fr);
        gap: 0.875rem;
        align-items: end;
      }
      .map-detail-search-input[type="date"] {
        min-width: 12.25rem;
        /* Date inputs already have a native picker affordance; free up text space. */
        padding-right: 1.25rem;
      }
      .map-detail-search-input[type="date"] + .map-detail-search-icon-right {
        display: none;
      }
      .map-detail-search-grid-top,
      .map-detail-search-grid-bottom {
        display: contents;
      }
      .map-detail-search-action {
        align-self: end;
      }
    }
    .map-detail-main-01 > .map-detail-aside-01 {
      position: absolute;
      top: 1rem;
      left: 1rem;
      bottom: 1rem;
      width: clamp(17rem, 32vw, 26rem);
      max-width: calc(100vw - 5rem);
    }
    .stay-marker {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
      cursor: pointer;
      transform: translateY(0);
      transition: transform 180ms ease;
      user-select: none;
    }
    .stay-marker:hover,
    .stay-marker.is-hover {
      transform: translateY(-6px);
    }
    .stay-marker__pin {
      width: 2.15rem;
      height: 2.15rem;
      border-radius: 9999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      box-shadow: 0 6px 14px rgba(15, 23, 42, 0.28);
      border: 2px solid rgba(255, 255, 255, 0.88);
      backdrop-filter: blur(2px);
    }
    .stay-marker__label {
      opacity: 1;
      transform: translateY(0);
      transition: background-color 150ms ease, transform 150ms ease;
      white-space: nowrap;
      background: rgba(15, 23, 42, 0.9);
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      border-radius: 9999px;
      padding: 0.2rem 0.55rem;
      box-shadow: 0 4px 10px rgba(15, 23, 42, 0.2);
      pointer-events: auto;
    }
    .stay-marker:hover .stay-marker__label,
    .stay-marker.is-hover .stay-marker__label {
      background: rgba(15, 23, 42, 0.98);
      transform: translateY(-1px);
    }
    .stay-marker--hotel .stay-marker__pin { background: linear-gradient(145deg, #1d4ed8, #2563eb); }
    .stay-marker--resort .stay-marker__pin { background: linear-gradient(145deg, #0891b2, #06b6d4); }
    .stay-marker--villa .stay-marker__pin { background: linear-gradient(145deg, #7c3aed, #8b5cf6); }
    .stay-marker--attraction .stay-marker__pin { background: linear-gradient(145deg, #ea580c, #f97316); }
    .nearby-poi-marker {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 9999px;
      background: linear-gradient(145deg, #f59e0b, #f97316);
      border: 2px solid rgba(255, 255, 255, 0.9);
      color: #fff;
      box-shadow: 0 6px 12px rgba(15, 23, 42, 0.2);
      cursor: pointer;
      transform: translateY(0);
      transition: transform 160ms ease;
    }
    .nearby-poi-marker:hover {
      transform: translateY(-4px);
    }
    @media (max-width: 640px) {
      .map-detail-search-grid-top,
      .map-detail-search-grid-bottom {
        grid-template-columns: minmax(0, 1fr);
      }
      .map-detail-search-submit {
        width: 100%;
      }
    }
    @media (max-width: 768px) {
      .map-detail-div-01 {
        padding: 0.5rem 0.75rem 0.75rem;
      }
      .map-detail-search-card {
        padding: 0.9rem;
        border-radius: 0.95rem;
      }
      .map-detail-search-grid-top {
        grid-template-columns: minmax(0, 1.35fr) repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
      }
      .map-detail-search-grid-bottom {
        grid-template-columns: minmax(0, 1fr) minmax(9.5rem, 0.9fr);
        gap: 0.75rem;
      }
      .map-detail-search-form {
        gap: 0.8rem;
      }
      .map-detail-search-select,
      .map-detail-search-input {
        min-height: 2.45rem;
        font-size: 0.9rem;
        padding: 0.65rem 2.25rem 0.65rem 2.2rem;
      }
      .map-detail-search-submit {
        min-width: 9.5rem;
        height: 2.45rem;
      }
      .map-detail-main-01 > .map-detail-aside-01 {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        bottom: 0.75rem;
        width: min(14.5rem, calc(100vw - 6rem));
        max-width: calc(100vw - 6rem);
      }
    }
    @media (max-width: 480px) {
      .map-detail-search-grid-top,
      .map-detail-search-grid-bottom {
        grid-template-columns: minmax(0, 1fr);
      }
      .map-detail-search-submit {
        width: 100%;
      }
      .map-detail-main-01 > .map-detail-aside-01 {
        width: min(13rem, calc(100vw - 5.25rem));
        max-width: calc(100vw - 5.25rem);
      }
    }
  </style>
</head>
<body class="page-body-screen-neutral-hidden map-detail-page">
  {{>partials/header}}

<div class="map-detail-div-01">
<div class="container-5xl-center">
<div class="map-detail-search-card">
<form class="map-detail-search-form" onsubmit="return false;">
<div class="map-detail-search-grid-top">
<div class="map-detail-search-field">
<label class="map-detail-search-label" for="mapRegion">광역시/도</label>
<div class="map-detail-search-control">
<span class="map-detail-search-icon-left icon-ms-18">location_on</span>
<select class="map-detail-search-select" id="mapRegion" name="region">
<option value="seoul">서울특별시</option>
<option value="busan" selected>부산광역시</option>
<option value="daegu">대구광역시</option>
<option value="incheon">인천광역시</option>
<option value="gwangju">광주광역시</option>
<option value="daejeon">대전광역시</option>
<option value="ulsan">울산광역시</option>
<option value="sejong">세종특별자치시</option>
<option value="gyeonggi">경기도</option>
<option value="gangwon">강원특별자치도</option>
<option value="chungbuk">충청북도</option>
<option value="chungnam">충청남도</option>
<option value="jeonbuk">전라북도</option>
<option value="jeonnam">전라남도</option>
<option value="gyeongbuk">경상북도</option>
<option value="gyeongnam">경상남도</option>
<option value="jeju">제주특별자치도</option>
</select>
<span class="map-detail-search-icon-right icon-ms-18">expand_more</span>
</div>
</div>
<div class="map-detail-search-field">
<label class="map-detail-search-label" for="mapStartDate">가는 날</label>
<div class="map-detail-search-control">
<span class="map-detail-search-icon-left icon-ms-18">calendar_today</span>
<input class="map-detail-search-input" id="mapStartDate" type="date" value="2025-11-15" required/>
<span class="map-detail-search-icon-right icon-ms-18">calendar_today</span>
</div>
</div>
<div class="map-detail-search-field">
<label class="map-detail-search-label" for="mapEndDate">오는 날</label>
<div class="map-detail-search-control">
<span class="map-detail-search-icon-left icon-ms-18">event</span>
<input class="map-detail-search-input" id="mapEndDate" type="date" value="2025-11-18" required/>
<span class="map-detail-search-icon-right icon-ms-18">calendar_today</span>
</div>
</div>
</div>
<div class="map-detail-search-grid-bottom">
<div class="map-detail-search-field">
<label class="map-detail-search-label" for="mapGuests">인원수</label>
<div class="map-detail-search-control">
<span class="map-detail-search-icon-left icon-ms-18">group</span>
<select class="map-detail-search-select" id="mapGuests" name="guests">
<option value="1">성인 1명</option>
<option value="2" selected>성인 2명</option>
<option value="3">성인 3명</option>
<option value="4">성인 4명</option>
<option value="group">단체 (5명 이상)</option>
</select>
<span class="map-detail-search-icon-right icon-ms-18">expand_more</span>
</div>
</div>
<div class="map-detail-search-action">
<button class="fx-group-cta-primary map-search-submit" type="button">
<span class="icon-ms-base">search</span>
<span>탐색하기</span>
</button>
</div>
</div>
</form>
</div>
</div>
<div class="timeline-chip-scroll">
<button class="map-detail-button-02 map-panel-toggle" type="button" data-map-panel-toggle aria-controls="mapResultPanel" aria-expanded="false">
<span class="icon-ms-16">hotel</span>
                    숙소
                </button>
<button class="map-detail-button-03" type="button" data-map-poi-toggle aria-controls="mapPoiPanel" aria-expanded="false">
<span class="icon-ms-16">attractions</span>
                    관광지
                </button>
<div class="map-detail-div-05"></div>
<button class="pill-neutral">
                    가격 범위
                    <span class="icon-ms-14">expand_more</span>
</button>
<button class="pill-neutral">
                    평점
                    <span class="icon-ms-14">expand_more</span>
</button>
<button class="pill-neutral">
                    필터 더보기
                    <span class="icon-ms-14">tune</span>
</button>
</div>
</div>
</div>
<main class="map-detail-main-01">
