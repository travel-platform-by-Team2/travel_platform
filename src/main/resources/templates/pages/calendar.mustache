<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Simplified Personal Calendar with Memo</title>
  {{>partials/head-assets}}
</head>
<body class="page-body-overflow-hidden-shell">
  {{>partials/header}}

<div class="calendar-add-event-div-01">
<main class="chat-panel-scroll-shell-rel">
<div class="calendar-header-sticky-high">
<div class="calendar-add-event-div-02">
<h1 class="heading-xl-tight">2025년 6월</h1>
<div class="pager-shell">
<button class="btn-round-soft">
<span class="icon-ms-20">chevron_left</span>
</button>
<button class="btn-round-soft">
<span class="icon-ms-20">chevron_right</span>
</button>
</div>
</div>
<div class="calendar-add-event-div-03">
<button class="btn-primary-lg-inline" type="button" data-calendar-event-open aria-expanded="false" aria-controls="calendar-event-panel">
<span class="icon-ms-20">add</span>
<span>일정 추가</span>
</button>
<div class="popover-panel-flyout" id="calendar-event-panel" data-calendar-event-panel hidden>
<div class="calendar-add-event-div-04">
<h3 class="heading-sm-strong">일정 추가</h3>
<button class="calendar-add-event-button-01" type="button" data-calendar-event-close>
<span class="icon-ms-base">close</span>
</button>
</div>
<div class="calendar-add-event-div-05">
<div>
<label class="label-xs-muted">일정 제목</label>
<input class="calendar-add-event-input-01" placeholder="예: 점심 약속, 제주도 여행" type="text"/>
</div>
<div class="stack-gap-3">
<div class="row-between-center">
<label class="calendar-add-event-label-01">일시</label>
<div class="inline-items-gap-2">
<span class="booking-complete-span-08">종일</span>
<button class="calendar-add-event-button-02">
<span class="calendar-add-event-span-01"></span>
</button>
</div>
</div>
<div class="calendar-add-event-div-06">
<div class="calendar-add-event-div-07">
<input class="input-prefix" type="text" value="2025. 06. 15"/>
<span class="icon-ms-18-input-left">calendar_today</span>
</div>
<div class="calendar-add-event-div-08">
<input class="input-suffix-center" type="text" value="14:00"/>
<span class="icon-ms-18-input-right">schedule</span>
</div>
</div>
<div class="calendar-add-event-div-06">
<div class="calendar-add-event-div-07">
<input class="input-prefix" type="text" value="2025. 06. 15"/>
<span class="icon-ms-18-input-left">calendar_today</span>
</div>
<div class="calendar-add-event-div-08">
<input class="input-suffix-center" type="text" value="15:00"/>
<span class="icon-ms-18-input-right">schedule</span>
</div>
</div>
</div>
<div>
<label class="calendar-add-event-label-02">카테고리</label>
<div class="calendar-add-event-div-09">
<button class="calendar-add-event-button-03">여행</button>
<button class="calendar-add-event-button-04">개인</button>
<button class="calendar-add-event-button-05">가족</button>
<button class="calendar-add-event-button-06">업무</button>
<button class="calendar-add-event-button-07">
<span class="icon-ms-16">add</span>
</button>
</div>
</div>
<div>
<label class="label-xs-muted">메모</label>
<textarea class="calendar-add-event-textarea-01" placeholder="메모를 입력하세요..." rows="3"></textarea>
</div>
</div>
<div class="calendar-add-event-div-10">
<button class="calendar-add-event-button-08" type="button" data-calendar-event-close>취소</button>
<button class="calendar-add-event-button-09">저장하기</button>
</div>
</div>
</div>
</div>
<div class="calendar-add-event-div-11">
<div class="calendar-week-grid-head">
<div class="calendar-add-event-div-12">일</div>
<div class="calendar-weekday-label">월</div>
<div class="calendar-weekday-label">화</div>
<div class="calendar-weekday-label">수</div>
<div class="calendar-weekday-label">목</div>
<div class="calendar-weekday-label">금</div>
<div class="calendar-weekday-label">토</div>
</div>
<div class="calendar-grid-shell">
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">26</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">27</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">28</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">29</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">30</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">31</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">1</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">2</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">3</span>
<div class="event-chip-rose">
                             병원 예약
                        </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">4</span>
<div class="event-chip-orange">
                             가족 모임 준비
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">5</span>
<div class="event-chip-red-strong">
                             현충일
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">6</span>
</div>
<div class="calendar-day-card">
<span class="text-error-caption">7</span>
<div class="event-chip-emerald">
                             개인 운동
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">8</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">9</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">10</span>
<div class="event-chip-blue">
<span class="icon-ms-12-mid-gap-right">travel_explore</span>
                             제주도 여행 준비
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">11</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">12</span>
<div class="event-chip-purple">
                             친구 생일 파티
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">13</span>
<div class="calendar-span-start">
<div class="event-bar-left-full">
<span class="icon-ms-14">flight_takeoff</span>
                                제주도 여행
                             </div>
</div>
</div>
<div class="calendar-day-card">
<span class="text-error-caption">14</span>
<div class="calendar-span-mid">
<div class="event-chip-primary-h6"></div>
</div>
<div class="event-chip-indigo">
<span class="icon-ms-12-mid-gap-right">hotel</span>
                            그랜드 조선 제주
                        </div>
</div>
<div class="calendar-day-active">
<span class="date-badge-primary">15</span>
<div class="calendar-span-mid">
<div class="event-chip-primary-h6"></div>
</div>
<div class="event-chip-indigo">
<span class="icon-ms-12-mid-gap-right">hotel</span>
                            숙소 연박
                        </div>
<div class="event-chip-orange">
                             저녁 식사 예약
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">16</span>
<div class="calendar-span-end">
<div class="event-bar-right-full"></div>
</div>
<div class="event-chip-blue">
<span class="icon-ms-12-mid-gap-right">flight_land</span>
                             서울 복귀
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">17</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">18</span>
<div class="event-chip-emerald">
                             개인 운동
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">19</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">20</span>
<div class="event-chip-yellow">
                             스터디 모임
                         </div>
</div>
<div class="calendar-day-card">
<span class="text-error-caption">21</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">22</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">23</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">24</span>
<div class="event-chip-cyan">
                             세차하기
                         </div>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">25</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">26</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">27</span>
<div class="event-chip-fuchsia">
                             월급날
                         </div>
</div>
<div class="calendar-day-card">
<span class="text-error-caption">28</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">29</span>
</div>
<div class="calendar-day-card">
<span class="calendar-day-number">30</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">1</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">2</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">3</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">4</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">5</span>
</div>
<div class="calendar-day-card-soft-muted">
<span class="text-muted-sm-medium">6</span>
</div>
</div>
</div>
</main>
<aside class="page-right-panel">
<div class="panel-header">
<div class="row-between-center-mb4">
<h2 class="calendar-add-event-h2-01">6월 15일 (일)</h2>
<button class="calendar-add-event-button-10">
<span class="icon-ms-base">more_horiz</span>
</button>
</div>
<div class="inline-row-gap2-mb6">
<span class="badge-primary-soft">제주도 여행</span>
<span class="calendar-add-event-span-02">3일차</span>
</div>
<div class="notice-sky-row">
<span class="icon-ms-4xl-primary">partly_cloudy_day</span>
<div>
<p class="text-main-base-bold">제주 서귀포시</p>
<p class="calendar-add-event-p-01">최고 24°C / 최저 18°C · 습도 60%</p>
</div>
</div>
</div>
<div class="panel-body-fill">
<div class="row-between-center-mb4">
<h3 class="title-row-md">
<span class="icon-ms-xl-amber">sticky_note_2</span>
                    메모
                </h3>
<div class="calendar-add-event-div-13">
<button class="calendar-add-event-button-11"><span class="icon-ms-lg">add</span></button>
</div>
</div>
<div class="scroll-stack">
<div class="info-card-amber">
<div class="row-between-start-mb2">
<span class="calendar-add-event-span-03">쇼핑 리스트</span>
<button class="action-fade-danger">
<span class="icon-ms-sm">close</span>
</button>
</div>
<p class="text-body-sm-relaxed">
                    - 감귤 초콜릿 5박스<br/>
                    - 오메기떡 (공항 픽업)<br/>
                    - 한라봉 1박스 (본가용)
                </p>
</div>
<div class="info-card-blue">
<div class="row-between-start-mb2">
<span class="calendar-add-event-span-04">렌트카 반납</span>
<button class="action-fade-danger">
<span class="icon-ms-sm">close</span>
</button>
</div>
<p class="text-body-sm-relaxed">
                    반납 시간: 6월 16일 10:30<br/>
                    주유 상태 확인 필요 (가득 채우기)
                </p>
</div>
<div class="calendar-add-event-div-14">
<textarea class="textarea-control" placeholder="자유롭게 메모를 작성하세요..."></textarea>
</div>
</div>
</div>
</aside>
</div>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
