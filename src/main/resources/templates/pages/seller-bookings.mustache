<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{sellerPageTitle}}</title>
  {{>partials/head-assets}}
  <link href="/css/seller.css" rel="stylesheet">
</head>
<body class="page-body-main-shell seller-body">
  {{>partials/header}}

  <main class="seller-shell">
    <div class="seller-shell__inner">
      {{>partials/seller-sidebar}}

      <section class="seller-content">
        <header class="seller-page-header">
          <div>
            <p class="seller-page-header__eyebrow">Bookings</p>
            <h1 class="seller-page-header__title">{{sellerPageTitle}}</h1>
            <p class="seller-page-header__description">{{sellerPageDescription}}</p>
          </div>
        </header>

        <section class="seller-stats-grid seller-stats-grid--three">
          <article class="seller-stat-card">
            <div class="seller-stat-card__head">
              <span class="seller-stat-card__label">오늘 체크인</span>
              <span class="material-symbols-outlined seller-stat-card__icon">login</span>
            </div>
            <strong class="seller-stat-card__value">12건</strong>
            <p class="seller-stat-card__meta is-positive">지난 24시간 대비 2% 증가</p>
          </article>
          <article class="seller-stat-card">
            <div class="seller-stat-card__head">
              <span class="seller-stat-card__label">대기 중인 예약</span>
              <span class="material-symbols-outlined seller-stat-card__icon">pending_actions</span>
            </div>
            <strong class="seller-stat-card__value">5건</strong>
            <p class="seller-stat-card__meta is-negative">미처리 항목 확인 필요</p>
          </article>
          <article class="seller-stat-card">
            <div class="seller-stat-card__head">
              <span class="seller-stat-card__label">취소 요청</span>
              <span class="material-symbols-outlined seller-stat-card__icon">cancel_presentation</span>
            </div>
            <strong class="seller-stat-card__value">2건</strong>
            <p class="seller-stat-card__meta">빠른 처리가 필요합니다.</p>
          </article>
        </section>

        <section class="seller-filter-card">
          <div class="seller-filter-grid seller-filter-grid--bookings">
            <label class="seller-field">
              <span class="seller-field__label">기간 선택</span>
              <input type="text" class="seller-input" value="2026.03.01 - 2026.03.31">
            </label>
            <label class="seller-field">
              <span class="seller-field__label">예약 상태</span>
              <select class="seller-select">
                <option>전체 상태</option>
                <option>예약확정</option>
                <option>이용완료</option>
                <option>취소</option>
              </select>
            </label>
            <label class="seller-field seller-field--grow">
              <span class="seller-field__label">검색</span>
              <input type="text" class="seller-input" placeholder="게스트명 또는 예약번호를 검색하세요.">
            </label>
          </div>
        </section>

        <article class="seller-card">
          <div class="seller-card__header">
            <div>
              <p class="seller-card__eyebrow">Reservation List</p>
              <h2 class="seller-card__title">예약 현황</h2>
            </div>
          </div>
          <div class="seller-table-wrap">
            <table class="seller-table">
              <thead>
              <tr>
                <th>예약번호</th>
                <th>게스트명</th>
                <th>상품명</th>
                <th>이용 날짜</th>
                <th>상태</th>
                <th class="text-end">결제 금액</th>
                <th class="text-center">관리</th>
              </tr>
              </thead>
              <tbody>
              <tr>
                <td>#BK-20260321</td>
                <td>김철수</td>
                <td>프리미엄 오션뷰 스위트</td>
                <td>
                  <div class="seller-table__title">2026.03.15</div>
                  <div class="seller-table__sub">~ 2026.03.17 (2박)</div>
                </td>
                <td><span class="seller-badge is-green">예약확정</span></td>
                <td class="text-end">450,000원</td>
                <td class="text-center"><button type="button" class="seller-table__icon-button"><span class="material-symbols-outlined">more_vert</span></button></td>
              </tr>
              <tr>
                <td>#BK-20260318</td>
                <td>이영희</td>
                <td>디럭스 더블룸</td>
                <td>
                  <div class="seller-table__title">2026.03.10</div>
                  <div class="seller-table__sub">~ 2026.03.11 (1박)</div>
                </td>
                <td><span class="seller-badge">이용완료</span></td>
                <td class="text-end">210,000원</td>
                <td class="text-center"><button type="button" class="seller-table__icon-button"><span class="material-symbols-outlined">more_vert</span></button></td>
              </tr>
              <tr>
                <td>#BK-20260315</td>
                <td>박민지</td>
                <td>스탠다드 트윈</td>
                <td>
                  <div class="seller-table__title">2026.03.05</div>
                  <div class="seller-table__sub">~ 2026.03.06 (1박)</div>
                </td>
                <td><span class="seller-badge is-red">취소</span></td>
                <td class="text-end">150,000원</td>
                <td class="text-center"><button type="button" class="seller-table__icon-button"><span class="material-symbols-outlined">more_vert</span></button></td>
              </tr>
              <tr>
                <td>#BK-20260322</td>
                <td>최수연</td>
                <td>가든 패밀리 하우스</td>
                <td>
                  <div class="seller-table__title">2026.03.20</div>
                  <div class="seller-table__sub">~ 2026.03.23 (3박)</div>
                </td>
                <td><span class="seller-badge is-blue">예약대기</span></td>
                <td class="text-end">620,000원</td>
                <td class="text-center"><button type="button" class="seller-table__icon-button"><span class="material-symbols-outlined">more_vert</span></button></td>
              </tr>
              </tbody>
            </table>
          </div>
          <div class="seller-card__footer">
            <p>전체 48건 중 1-4건 표시</p>
            <div class="seller-pagination">
              <button type="button" class="seller-pagination__button is-disabled">
                <span class="material-symbols-outlined">chevron_left</span>
              </button>
              <button type="button" class="seller-pagination__button is-active">1</button>
              <button type="button" class="seller-pagination__button">2</button>
              <button type="button" class="seller-pagination__button">3</button>
              <button type="button" class="seller-pagination__button">
                <span class="material-symbols-outlined">chevron_right</span>
              </button>
            </div>
          </div>
        </article>
      </section>
    </div>
  </main>

  {{>partials/chatbot}}
  {{>partials/footer}}
  {{>partials/scripts}}
</body>
</html>
