</nav>

<script>
  function setLoggedInNavActive(menuKey) {
    var links = document.querySelectorAll("[data-logged-in-nav]");
    links.forEach(function (link) {
      link.classList.remove("active", "fw-semibold");
    });

    var selectedLink = document.querySelector('[data-logged-in-nav="' + menuKey + '"]');
    if (selectedLink) {
      selectedLink.classList.add("active", "fw-semibold");
    }
  }

  function resolveLoggedInNavByPath(pathname) {
    if (pathname.indexOf("/bookings/map-detail") === 0) {
      return "explore";
    }
    if (pathname.indexOf("/trip") === 0 ) {
      return "trip";
    }
    if (pathname.indexOf("/calendar") === 0) {
      return "calendar";
    }
    if (pathname.indexOf("/boards") === 0) {
      return "community";
    }
    return null;
  }

  document.addEventListener("DOMContentLoaded", function () {
    var activeMenu = resolveLoggedInNavByPath(window.location.pathname);
    if (activeMenu) {
      setLoggedInNavActive(activeMenu);
    } else {
      var links = document.querySelectorAll("[data-logged-in-nav]");
      links.forEach(function (link) {
        link.classList.remove("active", "fw-semibold");
      });
    }
  });
</script>

