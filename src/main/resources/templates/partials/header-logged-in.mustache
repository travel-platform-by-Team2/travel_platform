">
  <div class="container">
    <a class="navbar-brand app-brand" href="/">TravelMate</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNav" aria-controls="appNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="appNav">
      <ul class="
        navbar-nav
        mx-auto
        mb-2
        mb-lg-0
      ">

        <li class="nav-item"><a class="nav-link" data-logged-in-nav="explore" href="/bookings/map-detail" onclick="setLoggedInNavActive('explore');">탐색</a></li>
        <li class="nav-item"><a class="nav-link" data-logged-in-nav="trip" href="/trip" onclick="setLoggedInNavActive('trip');">여행계획</a></li>
        <li class="nav-item"><a class="nav-link" data-logged-in-nav="calendar" href="/calendar" onclick="setLoggedInNavActive('calendar');">캘린더</a></li>
        <li class="nav-item"><a class="nav-link" data-logged-in-nav="community" href="/boards" onclick="setLoggedInNavActive('community');">커뮤니티</a></li>
      </ul>
      <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-2 mt-3 mt-lg-0">
