        <div class="dropdown">
          <button class="
            btn
            btn-outline-secondary
            btn-sm
            dropdown-toggle
          " type="button" data-bs-toggle="dropdown" aria-expanded="false">
            홍길동 님
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="#">마이페이지</a></li>
            <li><a class="dropdown-item" href="#">계정 설정</a></li>
