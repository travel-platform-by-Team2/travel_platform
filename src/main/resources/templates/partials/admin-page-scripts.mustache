<script>
  document.addEventListener("DOMContentLoaded", function () {
    var actionMenus = Array.prototype.slice.call(
      document.querySelectorAll("[data-admin-action-menu]")
    );

    if (!actionMenus.length) {
      return;
    }

    var openMenu = null;

    function positionMenu(menu) {
      if (!menu) {
        return;
      }

      var actionButton = menu.querySelector("[data-admin-action-button]");
      var actionCard = menu.querySelector("[data-admin-action-card]");

      if (!actionButton || !actionCard) {
        return;
      }

      var buttonRect = actionButton.getBoundingClientRect();
      var cardRect = actionCard.getBoundingClientRect();
      var viewportWidth = window.innerWidth;
      var viewportHeight = window.innerHeight;
      var gap = 10;

      var left = buttonRect.right - cardRect.width;
      var top = buttonRect.bottom + gap;

      if (left < gap) {
        left = gap;
      }

      if (left + cardRect.width > viewportWidth - gap) {
        left = viewportWidth - cardRect.width - gap;
      }

      if (top + cardRect.height > viewportHeight - gap) {
        top = buttonRect.top - cardRect.height - gap;
      }

      if (top < gap) {
        top = gap;
      }

      actionCard.style.left = left + "px";
      actionCard.style.top = top + "px";
    }

    function setMenuState(menu, shouldOpen) {
      if (!menu) {
        return;
      }

      var actionButton = menu.querySelector("[data-admin-action-button]");
      var actionCard = menu.querySelector("[data-admin-action-card]");

      if (!actionButton || !actionCard) {
        return;
      }

      menu.classList.toggle("is-open", shouldOpen);
      actionButton.setAttribute("aria-expanded", shouldOpen ? "true" : "false");
      actionCard.hidden = !shouldOpen;

      if (shouldOpen) {
        positionMenu(menu);
      } else {
        actionCard.style.left = "";
        actionCard.style.top = "";
      }
    }

    document.addEventListener("click", function (event) {
      var actionButton = event.target.closest("[data-admin-action-button]");
      var actionMenu = event.target.closest("[data-admin-action-menu]");
      var actionCard = event.target.closest("[data-admin-action-card]");

      if (actionButton && actionMenu) {
        if (openMenu && openMenu !== actionMenu) {
          setMenuState(openMenu, false);
        }

        openMenu = actionMenu;
        setMenuState(openMenu, true);
        return;
      }

      if (actionCard) {
        return;
      }

      if (openMenu) {
        setMenuState(openMenu, false);
        openMenu = null;
      }
    });

    window.addEventListener("resize", function () {
      if (openMenu) {
        positionMenu(openMenu);
      }
    });

    window.addEventListener("scroll", function () {
      if (openMenu) {
        positionMenu(openMenu);
      }
    }, true);
  });
</script>
