<script>
  document.addEventListener("DOMContentLoaded", function () {
    var actionMenus = Array.prototype.slice.call(
      document.querySelectorAll("[data-admin-action-menu]")
    );

    if (!actionMenus.length) {
      return;
    }

    var openMenu = null;

    function setMenuState(menu, shouldOpen) {
      if (!menu) {
        return;
      }

      var actionButton = menu.querySelector("[data-admin-action-button]");
      var actionCard = menu.querySelector("[data-admin-action-card]");

      if (!actionButton || !actionCard) {
        return;
      }

      menu.classList.toggle("is-open", shouldOpen);
      actionButton.setAttribute("aria-expanded", shouldOpen ? "true" : "false");
      actionCard.hidden = !shouldOpen;
    }

    document.addEventListener("click", function (event) {
      var actionButton = event.target.closest("[data-admin-action-button]");
      var actionMenu = event.target.closest("[data-admin-action-menu]");
      var actionCard = event.target.closest("[data-admin-action-card]");

      if (actionButton && actionMenu) {
        if (openMenu && openMenu !== actionMenu) {
          setMenuState(openMenu, false);
        }

        openMenu = actionMenu;
        setMenuState(openMenu, true);
        return;
      }

      if (actionCard) {
        return;
      }

      if (openMenu) {
        setMenuState(openMenu, false);
        openMenu = null;
      }
    });
  });
</script>
