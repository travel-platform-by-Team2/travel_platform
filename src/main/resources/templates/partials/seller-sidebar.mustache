<aside class="seller-sidebar">
  <div class="seller-sidebar__brand">
    <div class="seller-sidebar__brand-icon">
      <span class="material-symbols-outlined">storefront</span>
    </div>
    <div>
      <p class="seller-sidebar__brand-label">Partner workspace</p>
      <h2 class="seller-sidebar__brand-title">판매자 센터</h2>
      <p class="seller-sidebar__brand-email">{{sellerSidebarEmail}}</p>
    </div>
  </div>

  <nav class="seller-sidebar__nav">
    <a href="/seller" class="seller-sidebar__link {{#sellerDashboardActive}}is-active{{/sellerDashboardActive}}">
      <span class="material-symbols-outlined">dashboard</span>
      <span>대시보드</span>
    </a>
    <a href="/seller/products" class="seller-sidebar__link {{#sellerProductsActive}}is-active{{/sellerProductsActive}}">
      <span class="material-symbols-outlined">inventory_2</span>
      <span>상품관리</span>
    </a>
    <a href="/seller/bookings" class="seller-sidebar__link {{#sellerBookingsActive}}is-active{{/sellerBookingsActive}}">
      <span class="material-symbols-outlined">shopping_cart</span>
      <span>예약관리</span>
    </a>
    <a href="/seller/settlements" class="seller-sidebar__link {{#sellerSettlementsActive}}is-active{{/sellerSettlementsActive}}">
      <span class="material-symbols-outlined">payments</span>
      <span>정산내역</span>
    </a>
  </nav>

  <div class="seller-sidebar__footer">
    <p class="seller-sidebar__footer-label">센터 안내</p>
    <p class="seller-sidebar__footer-greeting">{{sellerSidebarGreeting}}</p>
    <p class="seller-sidebar__footer-copy">설정 버튼 대신 공통 안내 문구를 고정해 두었습니다.</p>
  </div>
</aside>
