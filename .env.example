# Copy this file to .env and fill real values.
# .env is git-ignored by default.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
OPENAI_ENDPOINT=https://api.openai.com/v1/responses
KAKAO_MAP_APP_KEY=카카오맵api키
TOUR_API_SERVICE_KEY=공공데이터_서비스키
WEATHER_API_KEY=공공데이터_서비스키
KAKAO_MAP_APP_KEY=YOUR_KAKAO_MAP_APP_KEY_HERE
KAKAO_JS_APP_KEY=YOUR_KAKAO_JS_APP_KEY_HERE
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID_HERE
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET_HERE
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE